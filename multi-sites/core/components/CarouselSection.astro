---
/**
 * CarouselSection.astro
 * Dynamic carousel for topics and articles
 * Usage: <CarouselSection topicsWithArticles={topicsWithArticles} />
 */
import ResponsiveImage from './ResponsiveImage.astro';
import { BlogService } from '../lib/blog-service.ts';
import path from 'path';

const limitPerTopic = 6;

// Fetch topics with articles dynamically
const topicsWithArticles = await BlogService.getTopicsWithArticles(limitPerTopic);

// Get businessId from siteConfig (Astro server)
import { siteConfig } from '../site-config.ts';
const businessId = siteConfig.site.business_id;

function buildSources(filename, breakpoints, scales, imageBase) {
    function buildSrcset(format) {
        const entries = [];

        breakpoints.forEach((bp) => {
            scales.forEach((scale) => {
                const realWidth = bp * scale;
                const file = `${filename}-${bp}-${scale}x.${format}`;

                entries.push(`${imageBase}${file} ${realWidth}w`);
            });
        });

        return entries.join(', ');
    }

    return {
        webp: buildSrcset('webp'),
        jpeg: buildSrcset('jpeg'),
    };
}

function safeImageName(image) {
    if (typeof image === 'string' && image.trim() !== '') {
        return path.parse(image).name;
    }
    return 'placeholder'; // ou qualquer nome de imagem padrão
}

---

<style>
    .carousel-container::-webkit-scrollbar {
        display: none;
    }
    .carousel-container {
        -ms-overflow-style: none;
        scrollbar-width: none;
        scroll-behavior: smooth;
    }
    .carousel-arrow-bar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin-bottom: -0.5rem;
        gap: 0.5rem;
    }
    .arrow-btn-subtle {
        background: none;
        border: 1px solid #d1d5db; /* Tailwind gray-300 */
        color: #6b7280; /* Tailwind gray-500 */
        width: 28px;
        height: 28px;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        cursor: pointer;
        transition:
            border-color 0.2s,
            color 0.2s;
        opacity: 0.6;
    }
    .arrow-btn-subtle:hover {
        border-color: #111; /* Tailwind blue-600 */
        opacity: 0.7;
    }
    .carousel-fade-right {
        position: absolute;
        top: 10px;
        right: 0;
        width: 64px;
        height: 100%;
        pointer-events: none;
        background: linear-gradient(to left, rgba(0, 0, 0, 0.1) 60%, rgba(255, 255, 255, 0));
        z-index: 10;
        opacity: 1;
        transition: opacity 0.2s;
    }
    .carousel-fade-right.hide {
        opacity: 0;
    }
</style>

<section class="w-full">
    {
        topicsWithArticles.length > 0 ? (
            topicsWithArticles.map((topic) => (
            <div class="relative mt-12 w-full">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <!-- Header row: title + buttons -->
                    <div class="flex items-end justify-between gap-4 mb-2">
                    <!-- Left: title + underline -->
                    <div>
                        <h2
                        id={topic.slug || topic.id}
                        class="text-3xl font-semibold"
                        >
                        {topic.title}
                        </h2>
                        <div class="w-1/6 border-b-2 border-gray-200 mt-2"></div>
                    </div>

                    <!-- Right: carousel buttons -->
                    <div class="carousel-arrow-bar flex gap-2">
                        <button
                        class="arrow-btn-subtle"
                        aria-label="Scroll left"
                        onclick={`document.querySelector('#carousel-${topic.slug || topic.id}').scrollBy({ left: -320, behavior: 'smooth' })`}
                        >
                        &#10094;
                        </button>

                        <button
                        class="arrow-btn-subtle"
                        aria-label="Scroll right"
                        onclick={`document.querySelector('#carousel-${topic.slug || topic.id}').scrollBy({ left: 320, behavior: 'smooth' })`}
                        >
                        &#10095;
                        </button>
                    </div>
                    </div>

                    <!-- Carousel -->
                    <div class="relative pt-2">
                    <div
                        id={`carousel-${topic.slug || topic.id}`}
                        data-topic-id={topic.id}
                        class="carousel-container flex gap-6 overflow-x-auto pb-4 pt-4 px-4"
                    >
                        {topic.blog_article.map((article, i) => (
                        <a
                            href={`/blog/${article.slug}/`}
                            class="bg-white transition-all duration-300 flex-shrink-0 w-80 shadow-none hover:scale-105 rounded-none cursor-pointer block"
                            style="text-decoration: none;"
                        >
                            <ResponsiveImage
                            alt={article.slug || article.title}
                            width={608}
                            height={320}
                            sizes="(max-width: 1023px) 320px, 608px"
                            sources={buildSources(
                                safeImageName(article.image),
                                [608, 320],
                                [1, 2],
                                `/assets/images/blog/resized/`
                            )}
                            blurDataURL={article.blurDataURL}
                            priority={i === 0}
                            class="w-full aspect-[1.67] object-cover"
                            />

                            <div class="p-6">
                            <h3 class="text-xl font-semibold mb-2 text-black">
                                {article.title.length > 70
                                ? article.title.slice(0, 70) + '...'
                                : article.title}
                            </h3>
                                <p class="text-gray-600 mb-4">
                                    {(article.seo_description || article.description || article.content_html || '')
                                        .replace(/<[^>]*>/g, '')
                                        .slice(0, 150) + '...'}
                                </p>
                            </div>
                        </a>
                        ))}
                    </div>

                    <div class="carousel-fade-right" />
                    </div>

                </div>
            </div>
            ))
        ) : (
            <div class="text-center py-12">
                <p class="text-gray-600 text-lg">Nenhum artigo encontrado.</p>
                <p class="text-gray-500 mt-2">Volte em breve para conferir nossos artigos!</p>
            </div>
        )
    }
</section>

<script define:vars={{ businessId }}>
    window.__BUSINESS_ID__ = businessId;
</script>

<script>
    // Configurable batch size
    const BATCH_SIZE = 6;

    // Real endpoint: returns next articles for a topic.
    // Returns an array on success (possibly empty = end of data),
    // or null on network/server error (so loadMore can retry later).
    async function fetchNextArticles(topicId, offset, limit) {
        const businessId = window.__BUSINESS_ID__;
        // Use same-origin URL — each site's nginx proxies /msitesapp/api/ → msitesapp Node server.
        // This avoids CORS issues entirely.
        const url = `${window.location.origin}/msitesapp/api/next-articles?business_id=${encodeURIComponent(businessId)}&blog_topic_id=${encodeURIComponent(topicId)}&offset=${offset}&limit=${limit}`;
        try {
            const res = await fetch(url);
            if (!res.ok) return null; // server error — allow retry
            const data = await res.json();
            // Map to expected card fields
            return (data.articles || []).map((a) => ({
                slug: a.slug,
                title: a.title,
                image: a.image || '',
                content_html: a.seo_description || '',
                blurDataURL: a.blur_base64 || ''
            }));
        } catch (err) {
            return null; // network error — allow retry
        }
    }

    // Spinner SVG
    const spinnerSVG = `<svg class='spinner' width='32' height='32' viewBox='0 0 32 32'><circle cx='16' cy='16' r='14' stroke='#2563eb' stroke-width='4' fill='none' opacity='0.2'/><circle cx='16' cy='16' r='14' stroke='#2563eb' stroke-width='4' fill='none' stroke-dasharray='22 88' stroke-linecap='round'><animateTransform attributeName='transform' type='rotate' from='0 16 16' to='360 16 16' dur='0.8s' repeatCount='indefinite'/></circle></svg>`;

    // State: loaded articles per topic
    const topicStates = {};

    function createResponsiveImageMinimal({
        imagePath, // ex: "/assets/images-responsive-base/resized/article3"
        breakpoints = [608, 320],
        scales = [1, 2],
        types = ["jpeg", "webp"],
        alt = "",
        className = "",
        priority = false,
        sizes = "(max-width: 1023px) 320px, 608px",
        width = null,
        height = null,
        blurDataURL = "",
    }) {
        const sources = {};
        const fallbackSrc = blurDataURL; // igual ao Astro

        // console.log('**** blurDataURL:', blurDataURL);

        // Gera srcsets iguais ao componente Astro
        types.forEach((type) => {
            const srcsetParts = [];

            breakpoints.forEach((bp) => {
                scales.forEach((scale) => {
                    const width = bp * scale;

                    // Nome igual ao Astro:
                    // basepath-<bp>-<scale>x.<ext>
                    const file = `${imagePath}-${bp}-${scale}x.${type}`;

                    srcsetParts.push(`${file} ${width}w`);
                });
            });

            sources[type] = srcsetParts.join(", ");
        });

        // <picture>
        const picture = document.createElement("picture");
        picture.className = `relative block ${className}`;
        picture.style.backgroundImage = `url('${fallbackSrc}')`;
        picture.style.backgroundSize = "cover";
        picture.style.backgroundPosition = "center";

        // <source> webp
        if (sources.webp) {
            const s = document.createElement("source");
            s.type = "image/webp";
            s.srcset = sources.webp;
            s.sizes = sizes;
            picture.appendChild(s);
        }

        // <source> jpeg
        if (sources.jpeg) {
            const s = document.createElement("source");
            s.type = "image/jpeg";
            s.srcset = sources.jpeg;
            s.sizes = sizes;
            picture.appendChild(s);
        }

        // <img> fallback = blur, SEM srcset
        const img = document.createElement("img");
        img.src = fallbackSrc; // igual ao Astro: blur no fallback
        img.alt = alt;
        if (width) img.width = width;
        if (height) img.height = height;
        img.loading = priority ? "eager" : "lazy";
        img.decoding = "async";
        img.className = "w-full h-full object-cover transition-opacity duration-300";
        img.style.opacity = "0";
        img.onload = () => (img.style.opacity = "1");

        picture.appendChild(img);

        return picture;
    }

    document.querySelectorAll('.carousel-container').forEach((carousel) => {
        const topicId = carousel.id.replace('carousel-', '');
        topicStates[topicId] = {
            loading: false,
            offset: carousel.children.length, // articles loaded server-side (before sentinel is added)
            done: false,
            topicId: carousel.getAttribute('data-topic-id'),
        };

        const fade = carousel.parentElement.querySelector('.carousel-fade-right');
        function updateFade() {
            const maxScroll = carousel.scrollWidth - carousel.clientWidth;
            if (maxScroll <= 0 || carousel.scrollLeft >= maxScroll - 4) {
                if (fade) fade.classList.remove('hide');
            } else {
                if (fade) fade.classList.add('hide');
            }
        }
        carousel.addEventListener('scroll', updateFade);
        setTimeout(updateFade, 100);

        // Prevent wheel scroll past the end
        carousel.addEventListener(
            'wheel',
            (e) => {
                const event = e as WheelEvent;
                const maxScroll = carousel.scrollWidth - carousel.clientWidth;
                if (
                    (carousel.scrollLeft === 0 && event.deltaX < 0) ||
                    (carousel.scrollLeft >= maxScroll && event.deltaX > 0)
                ) {
                    event.preventDefault();
                }
            },
            { passive: false }
        );

        async function loadMore() {
            if (topicStates[topicId].loading || topicStates[topicId].done) return;
            topicStates[topicId].loading = true;

            // Add spinner cards
            const spinners: HTMLElement[] = [];
            for (let i = 0; i < BATCH_SIZE; i++) {
                const spinnerCard = document.createElement('div');
                spinnerCard.className = 'bg-white flex-shrink-0 w-80';
                spinnerCard.innerHTML = `<div style='height:192px;width:100%;display:flex;align-items:center;justify-content:center;'>${spinnerSVG}</div><div class='p-6'></div>`;
                carousel.appendChild(spinnerCard);
                spinners.push(spinnerCard);
            }

            await new Promise((r) => setTimeout(r, 300));

            const nextArticles = await fetchNextArticles(
                topicStates[topicId].topicId,
                topicStates[topicId].offset,
                BATCH_SIZE
            );

            // Remove spinners
            spinners.forEach((s) => s.remove());

            if (nextArticles === null) {
                // Network/server error — don't set done, just release the lock so scroll can retry
            } else if (nextArticles.length === 0) {
                topicStates[topicId].done = true;
            } else {
                nextArticles.forEach((article) => {
                    const card = document.createElement('a');
                    card.href = `/blog/${article.slug}/`;
                    card.className =
                        'bg-white transition-all duration-300 flex-shrink-0 w-80 shadow-none hover:scale-105 rounded-none cursor-pointer block';
                    card.style.textDecoration = 'none';

                    const imgSrc = article.image
                        ? `/assets/images/blog/resized/${
                            article.image
                                .replace(/^.*\//, '')
                                .replace(/\.[^.]+$/, '')
                        }`
                        : '';

                    const img = createResponsiveImageMinimal({
                        imagePath: imgSrc,
                        breakpoints: [608, 320],
                        scales: [1, 2],
                        types: ['jpeg', 'webp'],
                        alt: article.slug,
                        className: 'w-full aspect-[1.67] object-cover',
                        priority: false,
                        sizes: '(max-width: 1023px) 320px, 608px',
                        width: null,
                        height: null,
                        blurDataURL: article.blurDataURL || '',
                    });

                    card.appendChild(img);
                    const infoDiv = document.createElement('div');
                    infoDiv.className = 'p-6';
                    infoDiv.innerHTML = `
                        <h3 class='text-xl font-semibold mb-2'>${article.title}</h3>
                        <p class='text-gray-600 mb-4'>${article.content_html}</p>
                    `;
                    card.appendChild(infoDiv);
                    carousel.appendChild(card);
                });

                topicStates[topicId].offset += nextArticles.length;
            }

            topicStates[topicId].loading = false;
        }

        // Scroll-based trigger: fires when within 2 card-widths (640px) of the end.
        // This is more reliable than IntersectionObserver with a horizontal root,
        // which does not support horizontal rootMargin in browsers.
        carousel.addEventListener('scroll', () => {
            const maxScroll = carousel.scrollWidth - carousel.clientWidth;
            const threshold = 640; // ~2 cards ahead
            if (maxScroll > 0 && carousel.scrollLeft >= maxScroll - threshold) {
                loadMore();
            }
        });
    });
</script>

