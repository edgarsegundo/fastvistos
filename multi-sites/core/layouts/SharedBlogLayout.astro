---
/**
 * 🚨 AUTO-GENERATED FILE. DO NOT EDIT.
 * This file is generated by sync-blog.js and will be overwritten.
 * To customize, edit the template.
 */

// Design system global: define as cores da marca e fontes via @theme (que gera automaticamente
// as classes Tailwind como bg-primary-500, text-secondary-500 etc), reset de elementos HTML
// via @layer base, e componentes compartilhados via @layer components.
// Deve ser importado em todos os layouts.
import '../styles/global.css';

import { siteConfig } from '../site-config.ts';

import HeadBasics from '../components/HeadBasics.astro';
import AnalyticsHead from '../components/AnalyticsHead.astro';
import AnalyticsBody from '../components/AnalyticsBody.astro';
import BlogPageHeader from '../components/BlogPageHeader.astro';
import BlogPageFooter from '../components/BlogPageFooter.astro';
import FaleCom from '../components/FaleCom.astro';

// Use full language tag (pt-BR) or just language (pt) based on site config
const lang = siteConfig.site.language || siteConfig.site.locale || 'pt-BR';
const htmlLang = siteConfig.site.useFullLanguageTag
    ? lang
    : lang.split('-')[0];

const {
    canonicalConf,
    faviconPathFromConf,
    seoFromConf,
    titleFromDb,
    descriptionFromDb,
    authorNameFromDb,
    imageFromDb,
    imageUrlFromDb,
    imageCaptionFromDb,
    imageWidthFromDb,
    imageHeightFromDb,
    pubDate,
    updatedDate,
} = Astro.props;
---

<!doctype html>
<html lang={htmlLang}>
    <head>
        <!-- Analytics Scripts -->
        <AnalyticsHead siteConfig={siteConfig} />

        <!-- Essential head elements (charset, viewport, etc.) -->
        <HeadBasics
            generator={Astro.generator}
            noIndex={false}
            enhancedIndexing={false}
            canonical={canonicalConf}
            faviconPath={faviconPathFromConf}
            seo={seoFromConf}
            title={titleFromDb}
            description={descriptionFromDb}
            authorName={authorNameFromDb}
            image={imageFromDb}
            imageUrl={imageUrlFromDb}
            imageCaption={imageCaptionFromDb}
            imageWidth={imageWidthFromDb}
            imageHeight={imageHeightFromDb}
            pubDate={pubDate}
            updatedDate={updatedDate}
        />

        <!-- TODO: Decidir o que fazer com isso -->
        <!-- Fonts & Styles -->
        <!-- <link rel="preconnect" href="https://fastvistos.com.br" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,700&display=swap"
            rel="stylesheet"
        /> -->

        <slot name="head" />
    </head>

    <!-- Cuidado, isso pode sobrescrever estilos globais nos arquivos global.css e theme.css
    <body
        class={`leading-normal tracking-normal`} -->

    <body
        class=""
        style=""
    >
        <!-- font-family: 'Source Sans Pro', sans-serif; -->
        
        <!-- Analytics Body Tags -->
        <AnalyticsBody siteConfig={siteConfig} />

        <!-- Header with exact dimensions -->
        <BlogPageHeader />

        <!-- Main content -->
        <slot />

        <!-- Footer -->
        <BlogPageFooter />
        <FaleCom /> 
    </body>
</html><script src="../lib/updatable-editor.js"></script>
