---
// https://chatgpt.com/share/69ab2149-1758-8010-9bb5-9454272fb731
import SharedHomeLayout from '../layouts/SharedHomeLayout.astro';
import { siteConfig } from '../site-config.ts';
import JsonLdHomePageBase from '../components/JsonLdHomePageBase.astro';

import Navigation from '../components/Navigation.astro';
import HeroSection from '../components/HeroSection.astro';
import VisaGuide from '../components/VisaGuide.astro';
// import ServicesSection from '../components/ServicesSection.astro';
// import PassportSection from '../components/PassportSection.astro';
import FaqSection from '../components/FaqSection.astro';
import FooterSection from '../components/FooterSection.astro';
import Whatsapp from '../components/Whatsapp.astro';
// import VideosSection from '../components/VideosSection.astro';
import CallToActionSection from '../components/CallToActionSection.astro';
import GoogleReviewsSection from '../components/GoogleReviewsSection.astro';
import CarouselSection from '../components/CarouselSection.astro';
// import HowItWorks from '../components/HowItWorks.astro';

const { bodyClass = '', bodyStyle = '' } = Astro.props;
---


<SharedHomeLayout
    bodyClass={`${bodyClass} gradient`}
    bodyStyle={`${bodyStyle}`}
    themeToggleDisable={true}
    canonicalConf={siteConfig.site.canonical}
    faviconPathFromConf={siteConfig.site.faviconPath}
    seoFromConf={siteConfig.homePageConfig.seo}
    titleFromConf={siteConfig.homePageConfig.seo.title}
    descriptionFromConf={siteConfig.homePageConfig.seo.description}
    authorNameFromConf={siteConfig.site.authorName}
    imageFromConf={null}
    imageUrlFromConf={siteConfig.site.primaryImage.url}
    imageCaptionFromConf={siteConfig.site.primaryImage.imageCaption}
    imageWidthFromConf={siteConfig.site.primaryImage.imageWidth}
    imageHeightFromConf={siteConfig.site.primaryImage.imageHeight}
>
    <!-- Additional head content specific to this layout -->
    <Fragment slot="head">
        <JsonLdHomePageBase
            faqList={[]}
            servicesList={[]}
            reviewsList={[]}
            disableReviews={false}
        />
    </Fragment>

    <!-- Body content -->
    <HeroSection />
    <CarouselSection />
    <FaqSection
        relativePath="multi-sites/sites/centraldevistos/components/FaqSection.astro"
        siteId={siteConfig.site.id}
    />
    <!-- <GoogleReviewsSection /> -->
    <!-- <CallToActionSection /> -->
    <FooterSection />
    <Whatsapp />    

</SharedHomeLayout>

<style is:global>
</style>

<!-- CSS specific to this page -->
<style>
</style>