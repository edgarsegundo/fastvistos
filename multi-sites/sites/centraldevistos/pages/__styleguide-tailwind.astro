<style>
    /* Ícone de cópia visível no hover */
    .color-card::after {
        content: "📋";
        position: absolute;
        top: 6px;
        right: 8px;
        font-size: 13px;
        opacity: 0;
        transition: opacity 150ms ease;
        pointer-events: none;
    }
    .color-card:hover::after {
        opacity: 1;
    } /* Overlay "Copiado!" ao clicar */
    .copy-badge {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 150ms ease;
        border-radius: inherit;
        z-index: 10;
    }
    .color-card.copied .copy-badge {
        opacity: 1;
    }
</style>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".color-card").forEach(function (card) {
            card.addEventListener("click", function () {
                var text = card.dataset.copy || "";
                console.log("clicou, texto:", text);
                navigator.clipboard
                    .writeText(text)
                    .then(function () {
                        console.log("copiou com sucesso");
                        card.classList.add("copied");
                        setTimeout(function () {
                            card.classList.remove("copied");
                        }, 1200);
                    })
                    .catch(function (err) {
                        console.log("erro no clipboard:", err);
                    });
            });
        });
    });
</script>