---
import PrototypeLayout from '../layouts/PrototypeLayout.astro';
---
<PrototypeLayout>
    <body class="bg-surface-alt text-text font-sans">
        <!-- HEADER -->
        <header class="bg-surface-inverse text-text-inverse px-8 py-12 mb-12">
            <div class="max-w-5xl mx-auto">
                <span
                    class="inline-block bg-white/20 text-white text-xs px-3 py-1 rounded-full tracking-widest uppercase mb-4"
                >
                    versão Tailwind — roda no projeto Astro
                </span>
                <h1 class="text-4xl font-bold leading-tight">Style Guide</h1>
                <p class="mt-2 text-lg opacity-80">
                    Referência visual com classes Tailwind geradas pelo
                    <code class="bg-black/20 px-2 py-0.5 rounded">theme.css</code>.
                    <span class="block text-sm mt-1 opacity-70"
                        >💡 Clique em qualquer cor semântica para copiar o nome da variável.</span
                    >
                </p>
            </div>
        </header>
        <div class="max-w-5xl mx-auto px-8 pb-24">
            <!-- ============ CORES ============ -->
            <section class="mb-20">
                <div class="text-xs uppercase tracking-widest text-text-muted border-b border-border pb-2 mb-6">
                    Paleta de Cores
                </div>
                <!-- Primary -->
                <div class="mb-6">
                    <div class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-3">
                        Primary — cor principal da marca <span class="lowercase">(bg-primary-??)</span>
                    </div>
                    <div class="flex rounded-lg overflow-hidden shadow-sm">
                        <div class="flex-1 h-16 bg-primary-50"></div>
                        <div class="flex-1 h-16 bg-primary-100"></div>
                        <div class="flex-1 h-16 bg-primary-200"></div>
                        <div class="flex-1 h-16 bg-primary-300"></div>
                        <div class="flex-1 h-16 bg-primary-400"></div>
                        <div class="flex-1 h-16 bg-primary-500 relative">
                            <span class="absolute bottom-1 left-1 text-white text-xs font-bold">500★</span>
                        </div>
                        <div class="flex-1 h-16 bg-primary-600"></div>
                        <div class="flex-1 h-16 bg-primary-700"></div>
                        <div class="flex-1 h-16 bg-primary-800"></div>
                        <div class="flex-1 h-16 bg-primary-900"></div>
                        <div class="flex-1 h-16 bg-primary-950"></div>
                    </div>
                    <div class="flex text-xs text-text-muted mt-1">
                        <span class="flex-1 text-center">50</span><span class="flex-1 text-center">100</span
                        ><span class="flex-1 text-center">200</span><span class="flex-1 text-center">300</span
                        ><span class="flex-1 text-center">400</span>
                        <span class="flex-1 text-center font-bold text-primary-600">500</span>
                        <span class="flex-1 text-center">600</span><span class="flex-1 text-center">700</span
                        ><span class="flex-1 text-center">800</span><span class="flex-1 text-center">900</span
                        ><span class="flex-1 text-center">950</span>
                    </div>
                </div>
                <!-- Secondary -->
                <div class="mb-6">
                    <div class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-3">
                        Secondary — cor de apoio, CTAs, badges <span class="lowercase">(bg-secondary-??)</span>
                    </div>
                    <div class="flex rounded-lg overflow-hidden shadow-sm">
                        <div class="flex-1 h-16 bg-secondary-50"></div>
                        <div class="flex-1 h-16 bg-secondary-100"></div>
                        <div class="flex-1 h-16 bg-secondary-200"></div>
                        <div class="flex-1 h-16 bg-secondary-300"></div>
                        <div class="flex-1 h-16 bg-secondary-400"></div>
                        <div class="flex-1 h-16 bg-secondary-500 relative">
                            <span class="absolute bottom-1 left-1 text-white text-xs font-bold">500★</span>
                        </div>
                        <div class="flex-1 h-16 bg-secondary-600"></div>
                        <div class="flex-1 h-16 bg-secondary-700"></div>
                        <div class="flex-1 h-16 bg-secondary-800"></div>
                        <div class="flex-1 h-16 bg-secondary-900"></div>
                        <div class="flex-1 h-16 bg-secondary-950"></div>
                    </div>
                    <div class="flex text-xs text-text-muted mt-1">
                        <span class="flex-1 text-center">50</span><span class="flex-1 text-center">100</span
                        ><span class="flex-1 text-center">200</span><span class="flex-1 text-center">300</span
                        ><span class="flex-1 text-center">400</span>
                        <span class="flex-1 text-center font-bold text-secondary-600">500</span>
                        <span class="flex-1 text-center">600</span><span class="flex-1 text-center">700</span
                        ><span class="flex-1 text-center">800</span><span class="flex-1 text-center">900</span
                        ><span class="flex-1 text-center">950</span>
                    </div>
                </div>
                <!-- Accent -->
                <div class="mb-10">
                    <div class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-3">
                        Accent — terceira cor, destaques pontuais <span class="lowercase">(bg-accent-??)</span>
                    </div>
                    <div class="flex rounded-lg overflow-hidden shadow-sm">
                        <div class="flex-1 h-16 bg-accent-50"></div>
                        <div class="flex-1 h-16 bg-accent-100"></div>
                        <div class="flex-1 h-16 bg-accent-200"></div>
                        <div class="flex-1 h-16 bg-accent-300"></div>
                        <div class="flex-1 h-16 bg-accent-400"></div>
                        <div class="flex-1 h-16 bg-accent-500 relative">
                            <span class="absolute bottom-1 left-1 text-white text-xs font-bold">500★</span>
                        </div>
                        <div class="flex-1 h-16 bg-accent-600"></div>
                        <div class="flex-1 h-16 bg-accent-700"></div>
                        <div class="flex-1 h-16 bg-accent-800"></div>
                        <div class="flex-1 h-16 bg-accent-900"></div>
                        <div class="flex-1 h-16 bg-accent-950"></div>
                    </div>
                    <div class="flex text-xs text-text-muted mt-1">
                        <span class="flex-1 text-center">50</span><span class="flex-1 text-center">100</span
                        ><span class="flex-1 text-center">200</span><span class="flex-1 text-center">300</span
                        ><span class="flex-1 text-center">400</span>
                        <span class="flex-1 text-center font-bold text-accent-600">500</span>
                        <span class="flex-1 text-center">600</span><span class="flex-1 text-center">700</span
                        ><span class="flex-1 text-center">800</span><span class="flex-1 text-center">900</span
                        ><span class="flex-1 text-center">950</span>
                    </div>
                </div>
                <!-- Semânticas — Texto -->
                <div class="mb-8">
                    <div class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-3">
                        Semânticas — Texto
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-text"
                        >
                            <div class="h-14" style="background-color: var(--color-text)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-text</div>
                                <div class="text-xs text-text-muted">corpo do texto, parágrafos</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-text-muted"
                        >
                            <div class="h-14" style="background-color: var(--color-text-muted)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-text-muted</div>
                                <div class="text-xs text-text-muted">legendas, metadados, placeholders</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-text-inverse"
                        >
                            <div class="h-14 bg-surface-inverse flex items-center justify-center px-3">
                                <span class="text-sm font-semibold" style="color: var(--color-text-inverse)"
                                    >Texto sobre fundo escuro</span
                                >
                            </div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-text-inverse</div>
                                <div class="text-xs text-text-muted">texto sobre fundos escuros</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-text-disabled"
                        >
                            <div class="h-14" style="background-color: var(--color-text-disabled)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-text-disabled</div>
                                <div class="text-xs text-text-muted">texto em elementos desabilitados</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Semânticas — Backgrounds (atualizado com novos tokens) -->
                <div class="mb-8">
                    <div class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-3">
                        Semânticas — Backgrounds
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-surface"
                        >
                            <div class="h-14 border border-border" style="background-color: var(--color-surface)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-surface</div>
                                <div class="text-xs text-text-muted">fundo padrão da página</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-surface-alt"
                        >
                            <div class="h-14" style="background-color: var(--color-surface-alt)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-surface-alt</div>
                                <div class="text-xs text-text-muted">seções alternadas (zebra)</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-surface-inverse"
                        >
                            <div class="h-14" style="background-color: var(--color-surface-inverse)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-surface-inverse</div>
                                <div class="text-xs text-text-muted">hero, seções escuras da marca</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-surface-card"
                        >
                            <div class="h-14" style="background-color: var(--color-surface-card)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-surface-card</div>
                                <div class="text-xs text-text-muted">fundo de cards, painéis</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-surface-raised"
                        >
                            <div class="h-14" style="background-color: var(--color-surface-raised)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-surface-raised</div>
                                <div class="text-xs text-text-muted">modais, dropdowns elevados</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-overlay"
                        >
                            <div class="h-14" style="background-color: var(--color-overlay)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-overlay</div>
                                <div class="text-xs text-text-muted">backdrop de modais</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-surface-disabled"
                        >
                            <div class="h-14" style="background-color: var(--color-surface-disabled)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-surface-disabled</div>
                                <div class="text-xs text-text-muted">fundo de elementos desabilitados</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Semânticas — Bordas e Interação -->
                <div class="mb-8">
                    <div class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-3">
                        Semânticas — Bordas e Interação
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-border"
                        >
                            <div class="h-14 bg-surface-alt flex items-center justify-center">
                                <div class="w-3/4 h-8 rounded border-2" style="border-color: var(--color-border)"></div>
                            </div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-border</div>
                                <div class="text-xs text-text-muted">divisores, bordas de cards e inputs</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-surface-hover"
                        >
                            <div class="h-14" style="background-color: var(--color-surface-hover)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-surface-hover</div>
                                <div class="text-xs text-text-muted">fundo ao passar o mouse em itens de menu</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-border-focus"
                        >
                            <div class="h-14 bg-surface-alt flex items-center justify-center">
                                <div
                                    class="w-3/4 h-8 rounded-lg border-2"
                                    style="border-color: var(--color-border-focus); box-shadow: 0 0 0 3px var(--color-border-focus)"
                                ></div>
                            </div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-border-focus</div>
                                <div class="text-xs text-text-muted">anel de foco (acessibilidade)</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Semânticas — Estados e Feedback -->
                <div class="mb-8">
                    <div class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-3">
                        Semânticas — Estados e Feedback
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-success"
                        >
                            <div class="h-14" style="background-color: var(--color-success)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-success</div>
                                <div class="text-xs text-text-muted">ícones e textos de sucesso</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-success-surface"
                        >
                            <div class="h-14" style="background-color: var(--color-success-surface)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-success-surface</div>
                                <div class="text-xs text-text-muted">fundo de alertas de sucesso</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-warning"
                        >
                            <div class="h-14" style="background-color: var(--color-warning)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-warning</div>
                                <div class="text-xs text-text-muted">ícones e textos de atenção</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-warning-surface"
                        >
                            <div class="h-14" style="background-color: var(--color-warning-surface)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-warning-surface</div>
                                <div class="text-xs text-text-muted">fundo de alertas de atenção</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-error"
                        >
                            <div class="h-14" style="background-color: var(--color-error)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-error</div>
                                <div class="text-xs text-text-muted">ícones e textos de erro</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-error-surface"
                        >
                            <div class="h-14" style="background-color: var(--color-error-surface)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-error-surface</div>
                                <div class="text-xs text-text-muted">fundo de alertas de erro</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-info"
                        >
                            <div class="h-14" style="background-color: var(--color-info)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-info</div>
                                <div class="text-xs text-text-muted">ícones e textos informativos</div>
                            </div>
                        </div>
                        <div
                            class="color-card rounded-lg overflow-hidden shadow-sm cursor-pointer relative group"
                            data-copy="--color-info-surface"
                        >
                            <div class="h-14" style="background-color: var(--color-info-surface)"></div>
                            <div class="copy-badge">✓ Copiado!</div>
                            <div class="bg-surface p-2 group-hover:bg-surface-alt transition-colors">
                                <div class="text-xs font-mono text-text">--color-info-surface</div>
                                <div class="text-xs text-text-muted">fundo de alertas informativos</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- ============ TIPOGRAFIA ============ -->
            <section class="mb-20">
                <div class="text-xs uppercase tracking-widest text-text-muted border-b border-border pb-2 mb-6">
                    Tipografia
                </div>
                <div class="space-y-3">
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">
                            text-4xl · --font-heading · títulos principais h1
                        </div>
                        <div class="text-4xl font-bold leading-tight">Breathe life into your walls</div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">
                            text-3xl · --font-heading · subtítulos h2
                        </div>
                        <div class="text-3xl font-bold leading-tight">Find What You're Looking For</div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">text-2xl · seções h3</div>
                        <div class="text-2xl">Interior & Exterior Wall Paints</div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">text-xl · lead, intro de seção</div>
                        <div class="text-xl">Premium quality, damp proof solutions</div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">
                            text-lg · corpo destacado, subtítulos pequenos
                        </div>
                        <div class="text-lg">Experience The Expertise Of Berger Paints</div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">
                            text-base · --font-sans · corpo padrão, parágrafos
                        </div>
                        <div class="text-base">
                            Precise quotations that include advice on products specific to your requirements.
                        </div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">
                            text-sm · legendas, labels, texto secundário
                        </div>
                        <div class="text-sm text-text-muted">Express Painting · Waterproofing · Products</div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">
                            text-xs · uppercase · tracking-widest · eyebrow, badges, tags
                        </div>
                        <div class="text-xs uppercase tracking-widest text-text-muted">
                            Style Guide · Referência Interna · v1.0
                        </div>
                    </div>
                    <div class="bg-surface-card rounded-xl p-6 shadow-sm">
                        <div class="font-mono text-xs text-text-muted mb-2">
                            font-mono · --font-mono · código, variáveis, valores técnicos
                        </div>
