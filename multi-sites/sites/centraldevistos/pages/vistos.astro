---
// src/pages/vistos.astro
import SharedGenericLayout from '../layouts/SharedGenericLayout.astro';
import Navigation from '../components/Navigation.astro';
import FooterSection from '../components/FooterSection.astro';
import Whatsapp from '../components/Whatsapp.astro';
import VisaGuide from '../components/VisaGuide.astro';
import { siteConfig } from '../site-config.ts';
---

<SharedGenericLayout
  titleFromConf="Guia de Vistos por País — Central de Vistos"
  descriptionFromConf="Tire dúvidas, entenda os requisitos e saiba o que precisa para viajar para qualquer país."
  canonicalConf="https://centraldevistos.com/vistos"
  faviconPathFromConf={siteConfig.site.faviconPath}
  seoFromConf={{
    title: 'Guia de Vistos por País — Central de Vistos',
    description: 'Tire dúvidas, entenda os requisitos e saiba o que precisa para viajar para qualquer país.',
    themeColor: '#0070f3',
    openGraph: {
      type: 'website',
      image: siteConfig.site.primaryImage,
      title: 'Guia de Vistos por País — Central de Vistos',
      description: 'Tire dúvidas, entenda os requisitos e saiba o que precisa para viajar para qualquer país.',
    }
  }}
  bodyClass="bg-gray-900">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>
  <Navigation />
  <VisaGuide />
  <FooterSection />
  <Whatsapp />
</SharedGenericLayout>
