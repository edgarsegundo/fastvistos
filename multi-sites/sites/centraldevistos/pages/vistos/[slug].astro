---
// src/pages/vistos/[slug].astro
// Página individual de visto por país — dados dinâmicos via visa-crawler

import SharedGenericLayout from '../../layouts/SharedGenericLayout.astro';
import Navigation from '../../components/Navigation.astro';
import FooterSection from '../../components/FooterSection.astro';
import Whatsapp from '../../components/Whatsapp.astro';
import { siteConfig } from '../../site-config.ts';

const API_BASE = import.meta.env.VISA_API_BASE || 'http://localhost:3001';

export async function getStaticPaths() {
  const apiBase = import.meta.env.VISA_API_BASE || 'http://localhost:3001';
  console.log(`[getStaticPaths] Usando API_BASE: ${apiBase}`); // <-- log solicitado
  const res = await fetch(`${apiBase}/api/visa-countries`);
  if (!res.ok) throw new Error(`[centraldevistos] /api/visa-countries falhou: HTTP ${res.status} — verifique se o serviço está rodando em ${apiBase}`);
  const countries = await res.json();
  if (!Array.isArray(countries) || countries.length === 0)
    throw new Error(`[centraldevistos] /api/visa-countries retornou lista vazia em ${apiBase}`);
  return countries.map((c: { id: string }) => ({ params: { slug: c.id } }));
}

const { slug } = Astro.params;
const apiData = await fetch(`${API_BASE}/api/visa/${slug}`).then(r => r.json());
const j = apiData.json_completo ?? {};

// Helpers
function flagFromIso(iso: string): string {
  if (!iso || iso.length !== 2) return '🌍';
  return [...iso.toUpperCase()].map(c => String.fromCodePoint(0x1F1E6 + c.charCodeAt(0) - 65)).join('');
}

function typeCodeFromLabel(label: string): string {
  const l = (label ?? '').toLowerCase();
  if (l.includes('isento') || l.includes('livre')) return 'free';
  if (l.includes('eta') || l.includes('visitor') || l.includes('nzeta') || l.includes('eletrôn')) return 'eta';
  return 'required';
}

// País
const nome = apiData.nome ?? slug;
const codigoIso = apiData.codigo_iso ?? '';
const flag = flagFromIso(codigoIso);
const typeLabel = j.typeLabel ?? apiData.type_label ?? 'Visto exigido';
const typeCode = typeCodeFromLabel(typeLabel);
const visaName = j.visaName ?? typeLabel;
const prazo = j.prazo ?? '—';
const validade = j.validade ?? j.estadia ?? '—';
const entrevista = j.entrevista ?? Boolean(apiData.entrevista);
const custo = j.custo != null ? String(j.custo) : 'Gratuito';
const documentos: string[] = j.documentos ?? [];
const vacinas: string[] = j.vacinas ?? [];
const consulados: { cidade: string; site: string }[] = j.consulados ?? [];
const observacoes: string = j.observacoes ?? '';
const fontes: string[] = j.fonte ?? [];
const recursos: { titulo: string; url: string; tipo: string }[] = j.recursos ?? [];
const confiabilidade: string = j.confiabilidade ?? apiData.confiabilidade ?? '';
const atualizadoEm: string = j.atualizadoEm ?? apiData.coletado_em ?? '';
const solicitacao: string = j.solicitacao ?? '';
const seguroSaude: boolean = Boolean(j.seguroSaude ?? apiData.seguro_saude);

const summary = solicitacao || `${visaName} — ${typeLabel}`;
const whatsappText = `Olá! Preciso de informações sobre visto para ${nome}.`;
const wppLink = `https://wa.me/551150283044?text=${encodeURIComponent(whatsappText)}`;
---

<SharedGenericLayout
  titleFromConf={`Visto para ${nome} — Central de Vistos`}
  descriptionFromConf={summary}
  canonicalConf={`https://centraldevistos.com/vistos/${slug}`}
  faviconPathFromConf={siteConfig.site.faviconPath}
  seoFromConf={{
    title: `Visto para ${nome} — Central de Vistos`,
    description: summary,
    themeColor: '#0070f3',
    openGraph: {
      type: 'article',
      image: siteConfig.site.primaryImage,
      title: `Visto para ${nome} — Central de Vistos`,
      description: summary,
    }
  }}
  bodyClass="gradient text-white">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>
  <Navigation />

<div class="country-page">
  <div class="cp-container">
  <div class="cp-card">

    <!-- Hero do país -->
    <div class="cp-hero">
      <div class="cp-hero-inner">
        <a href="/#visa-guide" class="cp-back">← Voltar ao guia</a>
        <div class="cp-flag">{flag}</div>
        <h1 class="cp-title">Visto para {nome}</h1>
        <p class="cp-summary">{summary}</p>
        <div class={`cp-type-badge cp-type--${typeCode}`}>{typeLabel}</div>
        {confiabilidade && (
          <div class={`cp-conf-badge cp-conf--${confiabilidade}`}>
            Confiabilidade: {confiabilidade}
          </div>
        )}
      </div>
    </div>

    <div class="cp-body">

    <!-- Info rápida -->
    <div class="cp-quick">
      <div class="cp-quick-item">
        <span class="cp-quick-label">Prazo de emissão</span>
        <span class="cp-quick-value">{prazo}</span>
      </div>
      <div class="cp-quick-item">
        <span class="cp-quick-label">Validade</span>
        <span class="cp-quick-value">{validade}</span>
      </div>
      <div class="cp-quick-item">
        <span class="cp-quick-label">Entrevista</span>
        <span class="cp-quick-value">{entrevista ? "Obrigatória" : "Não exige"}</span>
      </div>
      <div class="cp-quick-item">
        <span class="cp-quick-label">Taxa consular</span>
        <span class="cp-quick-value">{custo}</span>
      </div>
    </div>

    <!-- Alertas -->
    {seguroSaude && (
      <div class="cp-alert cp-alert--info">
        🏥 <strong>Seguro saúde obrigatório</strong> para este destino.
      </div>
    )}
    {observacoes && (
      <div class="cp-alert cp-alert--warn">
        ⚠️ {observacoes}
      </div>
    )}

    <!-- Tipo de visto -->
    <div class="cp-section">
      <h2 class="cp-section-title">Tipo de visto</h2>
      <div class="cp-tipos">
        <div class="cp-tipo-card">
          <div class="cp-tipo-code">{visaName}</div>
          <div class="cp-tipo-label">{typeLabel}</div>
          {solicitacao && <div class="cp-tipo-desc">{solicitacao}</div>}
        </div>
      </div>
    </div>

    <!-- Documentos -->
    {documentos.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Documentos necessários</h2>
        <ul class="cp-docs">
          {documentos.map((doc: string) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">✓</span>
              {doc}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Vacinas -->
    {vacinas.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Vacinas recomendadas / obrigatórias</h2>
        <ul class="cp-docs">
          {vacinas.map((v: string) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">💉</span>
              {v}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Consulados -->
    {consulados.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Consulados brasileiros</h2>
        <ul class="cp-docs">
          {consulados.map((c: { cidade: string; site: string }) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">🏛️</span>
              {c.site
                ? <a href={c.site} target="_blank" rel="noopener noreferrer">{c.cidade}</a>
                : c.cidade}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Recursos úteis -->
    {recursos.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Links úteis</h2>
        <ul class="cp-recursos">
          {recursos.map((r: { titulo: string; url: string; tipo: string }) => (
            <li class="cp-recurso-item">
              <a href={r.url} target="_blank" rel="noopener noreferrer">
                {r.titulo}
                <span class="cp-recurso-tipo">{r.tipo}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Fontes oficiais -->
    {fontes.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Fontes oficiais</h2>
        <ul class="cp-docs cp-fontes">
          {fontes.map((f: string) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">🔗</span>
              <a href={f} target="_blank" rel="noopener noreferrer" class="cp-fonte-link">{f}</a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {atualizadoEm && (
      <p class="cp-updated">Dados atualizados em: {atualizadoEm}</p>
    )}

    <!-- CTA -->
    <div class="cp-cta">
      <p class="cp-cta-text">
        Quer garantir a aprovação do seu visto para {nome}?<br/>
        Nossa equipe cuida de tudo por você.
      </p>
      <a href={wppLink} target="_blank" rel="noopener noreferrer" class="cp-wpp-btn wpp_button_link">
        💬 Solicitar assessoria — <strong>É Grátis!</strong>
      </a>
      <p class="cp-cta-sub">Operado pela equipe da <strong>FastVistos.com.br</strong></p>
    </div>

  </div><!-- /cp-body -->
  </div><!-- /cp-card -->
  </div><!-- /cp-container -->
</div><!-- /country-page -->

  <FooterSection />
  <Whatsapp />
</SharedGenericLayout>

<style>
  .country-page {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    padding: 0 16px 64px;
  }

  .cp-container {
    max-width: 860px;
    margin: 0 auto;
    padding-top: 32px;
  }

  .cp-card {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.45);
  }

  /* Hero */
  .cp-hero {
    background: linear-gradient(160deg, rgba(22,32,42,0.96) 0%, rgba(58,40,60,0.92) 100%);
    padding: 40px 24px 48px;
    position: relative;
    overflow: hidden;
  }

  .cp-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  .cp-hero-inner {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    text-align: center;
  }

  .cp-back {
    display: inline-block;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 0.2s;
  }

  .cp-back:hover { color: rgba(255,255,255,0.75); }

  .cp-flag { font-size: 56px; line-height: 1; margin-bottom: 12px; }

  .cp-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(24px, 6vw, 40px);
    font-weight: 800;
    color: #fff;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .cp-summary {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .cp-type-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
  }

  .cp-type--free     { background: rgba(37,162,68,0.2);  color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
  .cp-type--eta      { background: rgba(0,119,182,0.25); color: #60bfff; border: 1px solid rgba(96,191,255,0.3); }
  .cp-type--required { background: rgba(234,179,8,0.2);  color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }

  /* Body */
  .cp-body {
    background: #fff;
    padding: 28px 20px 40px;
  }

  @media (min-width: 640px) {
    .cp-body { padding: 36px 40px 48px; }
  }

  /* Quick info */
  .cp-quick {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 28px;
  }

  @media (min-width: 640px) {
    .cp-quick { grid-template-columns: repeat(4, 1fr); }
  }

  .cp-quick-item {
    background: #fff;
    border-radius: 14px;
    padding: 16px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cp-quick-label {
    font-size: 10px;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cp-quick-value {
    font-size: 14px;
    font-weight: 700;
    color: #1f2937;
    font-family: 'Sora', sans-serif;
  }

  /* Sections */
  .cp-section { margin-bottom: 28px; }

  .cp-section-title {
    font-family: 'Sora', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 14px;
  }

  /* Tipos */
  .cp-tipos { display: flex; flex-direction: column; gap: 10px; }

  @media (min-width: 640px) {
    .cp-tipos { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }

  .cp-tipo-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 16px;
  }

  .cp-tipo-code {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: #0077b6;
    background: rgba(0,119,182,0.08);
    padding: 2px 8px;
    border-radius: 6px;
    margin-bottom: 6px;
    font-family: 'Inter', sans-serif;
  }

  .cp-tipo-label {
    font-size: 14px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 4px;
    font-family: 'Sora', sans-serif;
  }

  .cp-tipo-desc { font-size: 13px; color: #6b7280; line-height: 1.5; }

  /* Docs */
  .cp-docs { list-style: none; display: flex; flex-direction: column; gap: 8px; }

  .cp-doc-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: #374151;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 12px 14px;
  }

  .cp-doc-check {
    color: #0077b6;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* CTA */
  .cp-cta {
    background: linear-gradient(301deg, #16202a 0%, #6f616d 100%);
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    margin-top: 32px;
  }

  .cp-cta-text {
    font-size: 15px;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .cp-wpp-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    color: #0077b6;
    font-family: 'Sora', sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 15px 28px;
    border-radius: 100px;
    text-decoration: none;
    box-shadow: 0 8px 28px rgba(0,0,0,0.25);
    transition: transform 0.2s;
    margin-bottom: 14px;
    display: inline-flex;
  }

  .cp-wpp-btn:hover { transform: translateY(-2px); }

  .cp-cta-sub {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    margin-top: 8px;
  }

  .cp-cta-sub strong { color: rgba(255,255,255,0.5); }

  /* Badge de confiabilidade */
  .cp-conf-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 100px;
    margin-top: 8px;
    font-family: 'Inter', sans-serif;
  }
  .cp-conf--alta    { background: rgba(37,162,68,0.15); color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
  .cp-conf--media   { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
  .cp-conf--baixa   { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(248,113,113,0.3); }

  /* Alertas */
  .cp-alert {
    border-radius: 12px;
    padding: 14px 18px;
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 20px;
  }
  .cp-alert--info { background: rgba(0,119,182,0.08); border: 1px solid rgba(0,119,182,0.2); color: #0077b6; }
  .cp-alert--warn { background: rgba(234,179,8,0.07); border: 1px solid rgba(234,179,8,0.25); color: #92400e; }

  /* Recursos */
  .cp-recursos { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .cp-recurso-item a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 14px;
    color: #0077b6;
    background: #fff;
    border: 1px solid #e0f0fa;
    border-radius: 10px;
    padding: 12px 14px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .cp-recurso-item a:hover { background: #f0f8ff; }
  .cp-recurso-tipo {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    background: rgba(0,119,182,0.1);
    color: #0077b6;
    padding: 2px 8px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  /* Fontes */
  .cp-fontes .cp-fonte-link {
    font-size: 12px;
    color: #6b7280;
    word-break: break-all;
    text-decoration: underline;
  }

  /* Data de atualização */
  .cp-updated {
    font-size: 11px;
    color: #9ca3af;
    text-align: right;
    margin-bottom: 20px;
    margin-top: -12px;
  }
</style>
