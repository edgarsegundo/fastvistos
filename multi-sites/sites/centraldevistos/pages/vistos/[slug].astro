---
// src/pages/vistos/[slug].astro
// Página individual de visto por país — dados dinâmicos via visa-crawler

import SharedGenericLayout from '../../layouts/SharedGenericLayout.astro';
import JsonLdVisaPage from '../../components/JsonLdVisaPage.astro';
import FooterSection from '../../components/FooterSection.astro';
import Whatsapp from '../../components/Whatsapp.astro';
import { siteConfig } from '../../site-config.ts';

import { ensureTrailingSlash } from '../../lib/utils.ts';

const API_BASE = import.meta.env.VISA_API_BASE || 'http://localhost:3001';

export async function getStaticPaths() {
  const apiBase = import.meta.env.VISA_API_BASE || 'http://localhost:3001';
  console.log(`[getStaticPaths] Usando API_BASE: ${apiBase}`); // <-- log solicitado
  const res = await fetch(`${apiBase}/api/visa-countries`);
  if (!res.ok) throw new Error(`[centraldevistos] /api/visa-countries falhou: HTTP ${res.status} — verifique se o serviço está rodando em ${apiBase}`);
  const countries = await res.json();
  if (!Array.isArray(countries) || countries.length === 0)
    throw new Error(`[centraldevistos] /api/visa-countries retornou lista vazia em ${apiBase}`);
  return countries.map((c: { id: string; slug: string }) => ({
    params: { slug: c.slug },
    props: { apiId: c.id },
  }));
}

const { slug } = Astro.params;
const { apiId } = Astro.props;
const apiData = await fetch(`${API_BASE}/api/visa/${apiId}`).then(r => r.json());
const j = apiData.json_completo ?? {};

// Helpers
function flagFromIso(iso: string): string {
  if (!iso || iso.length !== 2) return '🌍';
  return [...iso.toUpperCase()].map(c => String.fromCodePoint(0x1F1E6 + c.charCodeAt(0) - 65)).join('');
}

function typeCodeFromLabel(label: string): string {
  const l = (label ?? '').toLowerCase();
  if (l.includes('isento') || l.includes('livre')) return 'free';
  if (l.includes('eta') || l.includes('visitor') || l.includes('nzeta') || l.includes('eletrôn')) return 'eta';
  return 'required';
}

// País
const nome = apiData.nome ?? slug;
// console.log(`[${slug}] Dados do API:`, apiData); 
const codigoIso = apiData.pais_id ?? '';
// console.log('>>> codigoIso:', JSON.stringify(codigoIso), 'tipo:', typeof codigoIso);
const flag = flagFromIso(codigoIso);
// console.log('>>> flag:', flag);
const typeLabel = j.typeLabel ?? apiData.type_label ?? 'Visto exigido';
const typeCode = typeCodeFromLabel(typeLabel);
const visaName = j.visaName ?? typeLabel;
const prazo = j.prazo ?? '—';
const validade = j.validade ?? j.estadia ?? '—';
const entrevista = j.entrevista ?? Boolean(apiData.entrevista);
const custo = j.custo != null ? String(j.custo) : 'Gratuito';
const documentos: string[] = j.documentos ?? [];
const vacinas: string[] = j.vacinas ?? [];
const consulados: { cidade: string; site: string }[] = j.consulados ?? [];
const observacoes: string = j.observacoes ?? '';
const fontes: string[] = j.fonte ?? [];
const recursos: { titulo: string; url: string; tipo: string }[] = j.recursos ?? [];
const confiabilidade: string = j.confiabilidade ?? apiData.confiabilidade ?? '';
const atualizadoEm: string = j.atualizadoEm ?? apiData.coletado_em ?? '';
const solicitacao: string = j.solicitacao ?? '';
const seguroSaude: boolean = Boolean(j.seguroSaude ?? apiData.seguro_saude);

let summary = '';
// if (visaName && typeLabel && visaName !== typeLabel) {
//   summary = `${visaName} — ${typeLabel}`;
// } else if (visaName) {
if (visaName) {
  summary = visaName;
} else if (typeLabel) {
  summary = typeLabel;
} // se nenhum, summary fica vazio
const whatsappText = `Olá! Preciso de informações sobre visto para ${nome}.`;
const wppLink = `https://wa.me/551150283044?text=${encodeURIComponent(whatsappText)}`;

const currentYear = new Date().getFullYear();
const metaDescription = [
  `Saiba tudo sobre o visto para ${nome}`,
  documentos.length > 0 ? `documentos necessários` : null,
  prazo !== '—' ? `prazo de ${prazo}` : null,
  custo !== 'Gratuito' ? `taxa de ${custo}` : null,
  `e como solicitar em ${currentYear}. Assessoria especializada.`,
].filter(Boolean).join(', ');

const canonicalValidated = ensureTrailingSlash(siteConfig.site.canonical);
const canonicalVisto = `${canonicalValidated}vistos/${slug}/`;

// Create correct breadcrumb structure
const breadcrumbList = [
    {
        name: 'Home',
        item: siteConfig.site.canonical,
    },
    {
        name: 'Vistos',
        item: `${siteConfig.site.canonical}vistos/`,
    },
];
---

<SharedGenericLayout
  titleFromConf={`Visto para ${nome} | Requisitos, Custo e Como Solicitar ${currentYear}`}
  descriptionFromConf={metaDescription}
  canonicalConf={canonicalVisto}
  faviconPathFromConf={siteConfig.site.faviconPath}
  authorNameFromConf={siteConfig.organization?.name || siteConfig.site?.siteName}
  seoFromConf={{
    title: `Visto para ${nome} | Requisitos, Custo e Como Solicitar ${currentYear}`,
    description: metaDescription,
    themeColor: '#0070f3',
    openGraph: {
      type: 'article',
      image: siteConfig.site.primaryImage,
      title: `Visto para ${nome} | Requisitos, Custo e Como Solicitar ${currentYear}`,
      description: metaDescription,
    }
  }}
  bodyClass="bg-white"
  >

  <Fragment slot="head">
    <JsonLdVisaPage
      nome={nome}
      slug={slug}
      canonical={canonicalVisto}
      description={metaDescription}
      typeLabel={typeLabel}
      custo={custo}
      prazo={prazo}
      validade={validade}
      documentos={documentos}
      atualizadoEm={atualizadoEm}
    />
  
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>
  <!-- NAVBAR -->
  <header class="cp-nav">
    <div class="page-shell cp-nav-inner">
      <a href="/" class="cp-nav-logo">Central de Vistos</a>
      <nav class="cp-nav-links">
        <a href="/">Países</a>
        <a href="/">Vistos</a>
        <a href="/">Contato</a>
      </nav>
      <button id="nav-toggle" aria-label="Abrir menu" class="cp-nav-hamburger">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="26" height="26">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </header>

  <!-- Mobile overlay & drawer -->
  <div id="mobile-overlay" class="cp-overlay"></div>
  <aside id="mobile-menu" class="cp-drawer">
    <div class="cp-drawer-header">
      <span>Menu</span>
      <button id="nav-close" aria-label="Fechar menu">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="22" height="22">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="cp-drawer-nav">
      <a href="/">Países</a>
      <a href="/">Vistos</a>
      <a href="/">Contato</a>
      <a href="/blog/">Blog</a>
      <a href="https://fastvistos.com.br/formularios/">Formulários</a>
      <a href="#">☎ (11) 5028-3044</a>
    </nav>
  </aside>

<div class="country-page">
  <div class="page-shell cp-container">

    <!-- MINI HEADER -->
    <div class="cp-mini-header">
      <nav class="cp-breadcrumb" aria-label="breadcrumb">
        <a href="/">Início</a>
        <span>›</span>
        <span>Visto para {nome}</span>
      </nav>
      <div class="cp-mini-title">
        <span class="cp-mini-flag">{flag}</span>
        <div>
          <h1 class="cp-title">Visto para {nome}</h1>
          {summary && <p class="cp-summary">{summary}</p>}
        </div>
        <div class="cp-badges">
          <span class={`cp-type-badge cp-type--${typeCode}`}>{typeLabel}</span>
          {confiabilidade && (
            <span class={`cp-conf-badge cp-conf--${confiabilidade}`}>
              Confiabilidade: {confiabilidade}
            </span>
          )}
        </div>
      </div>
    </div>

  <div class="cp-card">

    <div class="cp-body">

    <!-- Info rápida -->
    <table class="cp-quick-table">
      <tbody>
        <tr>
          <td class="cp-qt-label">Prazo de emissão</td>
          <td class="cp-qt-value">{prazo}</td>
        </tr>
        <tr>
          <td class="cp-qt-label">Validade / Estadia</td>
          <td class="cp-qt-value">{validade}</td>
        </tr>
        <tr>
          <td class="cp-qt-label">Entrevista</td>
          <td class="cp-qt-value">{entrevista ? 'Obrigatória' : 'Não exige'}</td>
        </tr>
        <tr>
          <td class="cp-qt-label">Taxa consular</td>
          <td class="cp-qt-value">{custo}</td>
        </tr>
      </tbody>
    </table>

    <!-- Alertas -->
    {seguroSaude && (
      <div class="cp-alert cp-alert--info">
        🏥 <strong>Seguro saúde obrigatório</strong> para este destino.
      </div>
    )}
    {observacoes && (
      <div class="cp-alert cp-alert--warn">
        ⚠️ {observacoes}
      </div>
    )}

    <!-- Tipo de visto -->
    <div class="cp-section">
      <h2 class="cp-section-title">Tipo de visto</h2>
      <div class="cp-tipos">
        <div class="cp-tipo-card">
          <div class="cp-tipo-code">{visaName}</div>
          <div class="cp-tipo-label">{typeLabel}</div>
          {solicitacao && <div class="cp-tipo-desc">{solicitacao}</div>}
        </div>
      </div>
    </div>

    <!-- Documentos -->
    {documentos.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Documentos necessários</h2>
        <ul class="cp-docs">
          {documentos.map((doc: string) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">✓</span>
              {doc}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Card de Solicitação -->
    {solicitacao && (
      <div class="cp-section">
        <h2 class="cp-section-title">Dica Rápida para Solicitar</h2>
        <div class="cp-solicitacao-card">{solicitacao}</div>
      </div>
    )}

    <!-- Vacinas -->
    {vacinas.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Vacinas recomendadas / obrigatórias</h2>
        <ul class="cp-docs">
          {vacinas.map((v: string) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">💉</span>
              {v}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Consulados -->
    {consulados.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Consulados brasileiros</h2>
        <ul class="cp-docs">
          {consulados.map((c: { cidade: string; site: string }) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">🏛️</span>
              {c.site
                ? <a href={c.site} target="_blank" rel="noopener noreferrer">{c.cidade}</a>
                : c.cidade}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Recursos úteis -->
    {recursos.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Links úteis</h2>
        <ul class="cp-recursos">
          {recursos.map((r: { titulo: string; url: string; tipo: string }) => (
            <li class="cp-recurso-item">
              <a href={r.url} target="_blank" rel="noopener noreferrer">
                {r.titulo}
                <span class="cp-recurso-tipo">{r.tipo}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Fontes oficiais -->
    {fontes.length > 0 && (
      <div class="cp-section">
        <h2 class="cp-section-title">Fontes oficiais</h2>
        <ul class="cp-docs cp-fontes">
          {fontes.map((f: string) => (
            <li class="cp-doc-item">
              <span class="cp-doc-check">🔗</span>
              <a href={f} target="_blank" rel="noopener noreferrer" class="cp-fonte-link">{f}</a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {atualizadoEm && (
      <p class="cp-updated">Dados atualizados em: {atualizadoEm}</p>
    )}

    <!-- CTA -->
    <div class="cp-cta">
      <p class="cp-cta-text">
        Quer garantir a aprovação do seu visto para {nome}?<br/>
        Nossa equipe cuida de tudo por você.
      </p>
      <a href={wppLink} target="_blank" rel="noopener noreferrer" class="cp-wpp-btn wpp_button_link">
        💬 &nbsp;&nbsp;Solicitar assessoria</strong>
      </a>
      <p class="cp-cta-sub">Operado pela equipe da <strong>fastvistos.com.br</strong></p>
    </div>

  </div><!-- /cp-body -->
  </div><!-- /cp-card -->
  </div><!-- /cp-container -->
</div><!-- /country-page -->

  <FooterSection />
  <Whatsapp />
</SharedGenericLayout>

<style>
  /* ── Navbar ── */
  .cp-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
  }
  .cp-nav-inner {
    padding-block: 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cp-nav-logo {
    font-family: 'PT Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #111;
    text-decoration: none;
  }
  .cp-nav-links {
    display: none;
    gap: 28px;
    font-size: 14px;
    font-weight: 500;
    color: #374151;
  }
  .cp-nav-links a { color: #374151; text-decoration: none; transition: color 0.15s; }
  .cp-nav-links a:hover { color: #0077b6; }
  @media (min-width: 768px) { .cp-nav-links { display: flex; } }
  .cp-nav-hamburger {
    display: flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #374151;
  }
  @media (min-width: 768px) { .cp-nav-hamburger { display: none; } }

  /* Mobile drawer */
  .cp-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 40;
  }
  .cp-overlay.open { display: block; }
  .cp-drawer {
    position: fixed;
    top: 0; left: 0;
    height: 100%;
    width: 260px;
    background: #fff;
    z-index: 50;
    transform: translateX(-100%);
    transition: transform 0.28s ease;
    display: flex;
    flex-direction: column;
    box-shadow: 4px 0 24px rgba(0,0,0,0.10);
  }
  .cp-drawer.open { transform: translateX(0); }
  .cp-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid #e5e7eb;
    font-weight: 700;
    font-size: 16px;
  }
  .cp-drawer-header button { background: none; border: none; cursor: pointer; color: #6b7280; }
  .cp-drawer-nav {
    display: flex;
    flex-direction: column;
    padding: 20px 24px;
    gap: 4px;
  }
  .cp-drawer-nav a {
    padding: 10px 0;
    font-size: 15px;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    border-bottom: 1px solid #f3f4f6;
  }

  /* ── Page layout ── */
  .country-page {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    background: #fff;
    padding-bottom: 80px;
  }

  .cp-container {
    padding-top: 28px;
  }

  .cp-card {
    border-radius: 16px;
    border: 1px solid #e5e7eb;
    overflow: hidden;
    margin-bottom: 32px;
  }

  /* ── Mini header ── */
  .cp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #9ca3af;
    margin-bottom: 20px;
  }
  .cp-breadcrumb a { color: #9ca3af; text-decoration: none; }
  .cp-breadcrumb a:hover { color: #0077b6; }

  .cp-mini-header { margin-bottom: 28px; }

  .cp-mini-title {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cp-mini-flag { font-size: 52px; line-height: 1; flex-shrink: 0; margin-top: 2px; }

  .cp-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(22px, 5vw, 32px);
    font-weight: 800;
    color: #111;
    letter-spacing: -0.02em;
    margin: 0 0 4px;
  }

  .cp-summary {
    font-size: 14px;
    color: #6b7280;
    margin: 0;
  }

  .cp-badges { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }

  .cp-type-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
  }

  .cp-type--free     { background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }
  .cp-type--eta      { background: #dbeafe; color: #1d4ed8; border: 1px solid #bfdbfe; }
  .cp-type--required { background: #fef9c3; color: #a16207; border: 1px solid #fde68a; }

  /* Body */
  .cp-body {
    background: #fff;
    padding: 24px 20px 36px;
  }

  @media (min-width: 640px) {
    .cp-body { padding: 32px 36px 44px; }
  }

  /* Quick info table */
  .cp-quick-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 28px;
    font-size: 14px;
  }
  .cp-quick-table tr {
    border-bottom: 1px solid #f3f4f6;
  }
  .cp-quick-table tr:last-child { border-bottom: none; }
  .cp-qt-label {
    padding: 12px 0;
    color: #9ca3af;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: 45%;
    vertical-align: top;
  }
  .cp-qt-value {
    padding: 12px 0;
    color: #111;
    font-weight: 600;
    font-family: 'Sora', sans-serif;
    font-size: 14px;
  }

  /* Sections */
  .cp-section { margin-bottom: 28px; }

  .cp-section-title {
    font-family: 'Sora', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 14px;
  }

  /* Tipos */
  .cp-tipos { display: flex; flex-direction: column; gap: 10px; }

  @media (min-width: 640px) {
    .cp-tipos { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }

  .cp-tipo-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 16px;
  }

  .cp-tipo-code {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: #0077b6;
    background: rgba(0,119,182,0.08);
    padding: 2px 8px;
    border-radius: 6px;
    margin-bottom: 6px;
    font-family: 'Inter', sans-serif;
  }

  .cp-tipo-label {
    font-size: 14px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 4px;
    font-family: 'Sora', sans-serif;
  }

  .cp-tipo-desc { font-size: 13px; color: #6b7280; line-height: 1.5; }

  /* Docs */
  .cp-docs { list-style: none; display: flex; flex-direction: column; gap: 8px; }

  .cp-doc-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: #374151;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 12px 14px;
  }

  .cp-doc-check {
    color: #0077b6;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* CTA */
  .cp-cta {
    background: linear-gradient(301deg, #a0d2f4 0%, #60bfff 100%);
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    margin-top: 32px;
    box-shadow: 0 8px 32px rgba(96,191,255,0.15);
  }

  .cp-cta-text {
    font-size: 15px;
    color: #1a3651;
    line-height: 1.6;
    margin-bottom: 20px;
    font-weight: 600;
  }

  .cp-wpp-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    color: #0077b6;
    font-family: 'Sora', sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 15px 28px;
    border-radius: 100px;
    text-decoration: none;
    box-shadow: 0 8px 28px rgba(96,191,255,0.18);
    border: 2px solid #a0d2f4;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    margin-bottom: 14px;
  }

  .cp-wpp-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(96,191,255,0.25);
    border-color: #60bfff;
  }

  .cp-cta-sub {
    font-size: 12px;
    color: #1a3651cc;
    margin-top: 8px;
  }

  .cp-cta-sub strong { color: #0077b6; }

  /* Badge de confiabilidade */
  .cp-conf-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
  }
  .cp-conf--alta    { background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }
  .cp-conf--media   { background: #fef9c3; color: #a16207; border: 1px solid #fde68a; }
  .cp-conf--baixa   { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }

  /* Alertas */
