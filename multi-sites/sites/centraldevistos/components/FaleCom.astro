---
const {
  phone = "551150283044",
  message = "Olá! Gostaria de falar com um especialista.",
  avatar = "/assets/images/cta/fale-conosco.png",
  logo = "/assets/images/cta/logo-fast-orange.png"
} = Astro.props;

const whatsappLink = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<div class="fixed bottom-5 right-5 z-[9999] flex items-center group">

  <!-- BOX: oculto em mobile, visível em sm+ -->
  <div class="
    hidden sm:flex
    w-[16.25rem]
    bg-white/80 backdrop-blur-md
    rounded-xl
    py-3 pl-5 pr-4
    shadow-[0_10px_30px_rgba(0,0,0,0.12)]
    flex-col justify-center
    -mr-[30px] z-[1]
    transition-all duration-[250ms] ease-in-out
    group-hover:-translate-y-0.5
  ">
    <strong class="flex items-center gap-1.5 text-base font-semibold leading-tight">
      <svg .../>
      Fale com especialista
    </strong>
    <div class="flex flex-col mt-1 leading-none">
      <span class="text-[0.625rem] text-[#888] mb-0.5">Powered by</span>
      <img src={logo} alt="Fast Vistos" class="w-[5.5rem]" />
    </div>
  </div>

  <!-- AVATAR: menor em mobile -->
  <div class="
    w-[4rem] h-[4rem]
    sm:w-[7.5rem] sm:h-[7.5rem]
    rounded-full bg-white/80 backdrop-blur-md p-0.5
    shadow-[0_10px_25px_rgba(0,0,0,0.15)]
    flex items-center justify-center
    z-[2]
  ">
    <img src={avatar} alt="Atendimento" class="w-full h-full object-contain" />
  </div>
  <!-- <span class="absolute bottom-0 right-0 text-[0.6rem] text-white font-medium bg-black/40 rounded-full px-1.5 py-0.5 z-[4]">Atendimento</span> -->

  <a href={whatsappLink} target="_blank" class="absolute inset-0 z-[3]"></a>
</div>