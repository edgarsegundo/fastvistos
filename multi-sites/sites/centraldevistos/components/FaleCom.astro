---
const {
  phone = "551150283044",
  message = "Olá! Gostaria de falar com um especialista.",
  avatar = "/assets/images/cta/fale-conosco.png",
  logo = "/assets/images/cta/logo-fast-orange.png"
} = Astro.props;

const whatsappLink = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<div class="fixed bottom-5 right-5 z-[9999] flex items-center group">

  <!-- BOX -->
  <div class="
    w-[13.4rem]
    bg-white/80 backdrop-blur-md
    rounded-xl
    py-2.5 pl-4 pr-3.5
    shadow-[0_10px_30px_rgba(0,0,0,0.12)]
    flex flex-col justify-center
    -mr-[30px] z-[1]
    transition-all duration-[250ms] ease-in-out
    group-hover:-translate-y-0.5
    sm:w-[16.25rem] sm:py-3 sm:pl-5 sm:pr-4
  ">
    <strong class="flex items-center gap-1.5 text-[0.85rem] font-semibold leading-tight sm:text-base">
      <svg
        width="14" height="14"
        viewBox="0 0 1792 1792"
        xmlns="http://www.w3.org/2000/svg"
        fill="#25D366"
        class="shrink-0"
      >
        <path d="M1113 974q13 0 97.5 44t89.5 53q2 5 2 15 0 33-17 76-16 39-71 65.5t-102 26.5q-57 0-190-62-98-45-170-118t-148-185q-72-107-71-194v-8q3-91 74-158 24-22 52-22 6 0 18 1.5t19 1.5q19 0 26.5 6.5t15.5 27.5q8 20 33 88t25 75q0 21-34.5 57.5t-34.5 46.5q0 7 5 15 34 73 102 137 56 53 151 101 12 7 22 7 15 0 54-48.5t52-48.5zm-203 530q127 0 243.5-50t200.5-134 134-200.5 50-243.5-50-243.5-134-200.5-200.5-134-243.5-50-243.5 50-200.5 134-134 200.5-50 243.5q0 203 120 368l-79 233 242-77q158 104 345 104zm0-1382q153 0 292.5 60t240.5 161 161 240.5 60 292.5-60 292.5-161 240.5-240.5 161-292.5 60q-195 0-365-94l-417 134 136-405q-108-178-108-389 0-153 60-292.5t161-240.5 240.5-161 292.5-60z"/>
      </svg>
      Fale com especialista
    </strong>

    <div class="flex flex-col mt-1 leading-none">
      <span class="text-[0.625rem] text-[#888] mb-0.5">Powered by</span>
      <img src={logo} alt="Fast Vistos" class="w-[5.5rem]" />
    </div>
  </div>

  <!-- AVATAR -->
  <div class="
    w-[5.5rem] h-[5.5rem]
    rounded-full bg-white/80 backdrop-blur-md p-0.5
    shadow-[0_10px_25px_rgba(0,0,0,0.15)]
    flex items-center justify-center
    z-[2]
    sm:w-[7.5rem] sm:h-[7.5rem]
  ">
    <img src={avatar} alt="Atendimento" class="w-full h-full object-contain" />
  </div>

  <!-- LINK overlay -->
  <a href={whatsappLink} target="_blank" class="absolute inset-0 z-[3]"></a>
</div>