---
const {
  phone = "5511999999999",
  message = "Olá! Gostaria de falar com um especialista.",
  avatar = "/fale-conosco2.png",
  logo = "/logo-fast-orange.png"
} = Astro.props;

const whatsappLink = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<div class="cta">
  <div class="cta-box">
    <strong class="cta-title">
      <svg viewBox="0 0 32 32" class="cta-whatsapp">
        <path d="M16 3C9.4 3 4 8.4 4 15c0 2.6.8 5 2.2 7l-1.5 5.5 5.6-1.5c1.9 1.1 4 1.7 6.2 1.7 6.6 0 12-5.4 12-12S22.6 3 16 3z"/>
      </svg>
      Fale com especialista
    </strong>

    <div class="cta-powered">
      <span>Powered by</span>
      <img src={logo} alt="Fast Vistos" />
    </div>
  </div>

  <div class="cta-avatar">
    <img src={avatar} alt="Atendimento" />
  </div>

  <a href={whatsappLink} target="_blank" class="cta-link"></a>
</div>

<style>
.cta {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 9999;
  display: flex;
  align-items: center;
}

/* BOX */
.cta-box {
  width: 11.25rem; /* 180px */
  background: white;
  border-radius: 0.75rem;
  padding: 0.75rem 1rem 0.75rem 1.25rem;
  box-shadow: 0 10px 30px rgba(0,0,0,0.12);

  display: flex;
  flex-direction: column;
  justify-content: center;

  margin-right: -30px;
  z-index: 1;
  transition: all 0.25s ease;
}

.cta:hover .cta-box {
  transform: translateY(-2px);
}

/* TITLE */
.cta-title {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 1.125rem;
  font-weight: 600;
  line-height: 1.2;
}

/* ICON */
.cta-whatsapp {
  width: 0.875rem;
  height: 0.875rem;
  fill: #999;
}

/* POWERED */
.cta-powered {
  display: flex;
  flex-direction: column;
  margin-top: 0.25rem;
  line-height: 1;
}

.cta-powered span {
  font-size: 0.625rem;
  color: #888;
  margin-bottom: 0.125rem;
}

.cta-powered img {
  width: 5.5rem;
}

/* AVATAR */
.cta-avatar {
  width: 8.5rem;  /* 136px */
  height: 8.5rem;
  border-radius: 50%;
  background: white;
  padding: 2px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.15);

  display: flex;
  align-items: center;
  justify-content: center;

  z-index: 2;
}

.cta-avatar img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* LINK */
.cta-link {
  position: absolute;
  inset: 0;
  z-index: 3;
}

/* MOBILE */
@media (max-width: 600px) {
  .cta-avatar {
    width: 5.5rem;
    height: 5.5rem;
  }

  .cta-box {
    width: 10rem;
    padding: 0.625rem 0.875rem 0.625rem 1rem;
  }

  .cta-powered span {
    display: none;
  }
}
</style>