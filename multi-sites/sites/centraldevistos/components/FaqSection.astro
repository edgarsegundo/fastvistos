// FAQ Section Component with inline data
import { getFaqJson } from '../lib/faq-json';
import type { Faq } from '../lib/faq-json';

export interface Props {
    relativePath: string;
    siteId: string;
}

const { relativePath, siteId } = Astro.props;

let faqData: Faq[];

try {
    faqData = await getFaqJson(siteId); // Pass siteId dynamically
    console.log(`✅ Fetched ${faqData.length} FAQ items for site ${siteId}`);
} catch (err) {
    console.error(`🛑🛑 Failed to fetch FAQ data for site ${siteId}:`, err);
    faqData = [];
}

function formatAnswerForDisplay(answer: string) {
    return answer.replace(/\n/g, '<br>');
}
---

<section class="bg-white border-b py-16" id="faq">
    <div class="container max-w-5xl mx-auto m-8">
        <h2 class="faq-title w-full my-2 text-center">
            Perguntas Frequentes
        </h2>
        <div class="w-full mb-4">
            <div class="faq-divider h-1 mx-auto w-64 opacity-25 my-0 py-0 rounded-t"></div>
        </div>

        <div class="max-w-4xl mx-auto mt-12">
            {
                faqData.map((faq, index) => (
                    <div class="faq-item border-b border-gray-200 mb-4">
                        <button class="faq-question w-full text-left py-4 px-6 transition-colors duration-200 rounded-lg mb-2 flex justify-between items-center focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <h3 class="faq-question-text">
                                {faq.question}
                            </h3>
                            <svg
                                class="faq-icon w-5 h-5 transform transition-transform duration-300"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                        <div class="faq-answer hidden px-6 pb-4 rounded-b-lg -mt-[2px] border-l-4">
                            <p
                                class="faq-answer-text leading-relaxed"
                                set:html={formatAnswerForDisplay(faq.answer)}
                            />
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    /* ── Tokens com fallback — sobrescreva no theme.css do site ── */

    /* h2 */
    .faq-title {
        color: var(--faq-title-color, #1B375C);
        font-size: var(--faq-title-size, 2.5rem);
        font-weight: var(--faq-title-weight, 700);
        line-height: 1.2;
    }

    /* divisor */
    .faq-divider {
        background-color: var(--faq-divider-color, #0c59be);
    }

    /* botão da pergunta */
    .faq-question {
        background-color: var(--faq-question-bg, #f9fafb);
    }
    .faq-question:hover {
        background-color: var(--faq-question-hover-bg, #f3f4f6);
    }
    .faq-question[aria-expanded='true'] {
        background-color: var(--faq-question-active-bg, #e9ecef);
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
    }
    .faq-question[aria-expanded='true'] .faq-icon {
        transform: rotate(180deg);
    }

    /* texto h3 */
    .faq-question-text {
        color: var(--faq-question-color, #1B375C);
        font-size: var(--faq-question-size, 1.125rem);
        font-weight: var(--faq-question-weight, 600);
    }

    /* resposta */
    .faq-answer {
        background-color: var(--faq-answer-bg, #f8f9fa);
        border-left-color: var(--faq-answer-accent, #ff8700);
    }
    .faq-answer-text {
        color: var(--faq-answer-text-color, #4b5563);
    }

    .faq-answer.show {
        display: block;
        animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<script is:inline>
    (function () {
        document.addEventListener('DOMContentLoaded', function () {
            var faqQuestions = document.querySelectorAll('.faq-question');

            for (var i = 0; i < faqQuestions.length; i++) {
                var question = faqQuestions[i];
                question.setAttribute('aria-expanded', 'false');

                question.addEventListener('click', function (event) {
                    var currentButton = event.currentTarget;
                    var faqItem = currentButton.closest('.faq-item');
                    var answer = faqItem.querySelector('.faq-answer');
                    var isExpanded = currentButton.getAttribute('aria-expanded') === 'true';

                    // Close all other FAQ items
                    for (var j = 0; j < faqQuestions.length; j++) {
                        var otherQuestion = faqQuestions[j];
                        if (otherQuestion !== currentButton) {
                            var otherFaqItem = otherQuestion.closest('.faq-item');
                            var otherAnswer = otherFaqItem.querySelector('.faq-answer');

                            otherQuestion.setAttribute('aria-expanded', 'false');
                            if (otherAnswer) {
                                otherAnswer.classList.add('hidden');
                                otherAnswer.classList.remove('show');
                            }
                        }
                    }

                    // Toggle current FAQ item
                    if (isExpanded) {
                        currentButton.setAttribute('aria-expanded', 'false');
                        if (answer) {
                            answer.classList.add('hidden');
                            answer.classList.remove('show');
                        }
                    } else {
                        currentButton.setAttribute('aria-expanded', 'true');
                        if (answer) {
                            answer.classList.remove('hidden');
                            answer.classList.add('show');
                        }
                    }
                });
            }
        });
    })();
</script>
