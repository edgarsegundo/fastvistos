---
// Navigation component with logo and menu
---

<nav id="header" class="w-full z-50 top-0 text-white bg-surface-inverse">
    <div class="w-full container mx-auto flex flex-wrap items-center justify-between mt-0 py-4">
        <div class="pl-4 flex flex-col items-start">
            <a class="toggleColour no-underline hover:no-underline" href="/">
                <div class="site-name">centraldevistos.com</div>
                <div class="flex items-center gap-2 site-operado">
                    <span>OPERADO POR</span>
                    <img
                        src="/assets/images/logo/logo-desktop.png"
                        class="h-5 w-auto"
                        alt="FastVistos"
                    />
                </div>
            </a>
        </div>
        <div class="block lg:hidden pr-4">
            <button
                id="nav-toggle"
                aria-label="Abrir menu"
                class="flex items-center p-1 text-pink-800 hover:text-gray-900 focus:outline-none focus:shadow-outline transform transition hover:scale-105 duration-300 ease-in-out"
            >
                <svg
                    class="fill-current text-white h-6 w-6"
                    viewBox="0 0 20 20"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <title>Menu</title>
                    <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"></path>
                </svg>
            </button>
        </div>
        <div
            id="nav-content"
            class="w-full flex-grow lg:flex lg:items-center lg:w-auto hidden mt-2 lg:mt-0 lg:bg-transparent p-4 lg:p-0 z-20"
        >
            <ul class="list-reset lg:flex justify-end flex-1 items-center">
                <!-- <li class="mr-3">
                    <a
                        class="inline-block top-link text-black lg:text-gray-300 py-2 px-4 font-bold no-underline link-click"
                        href="#casos-de-sucesso"
                        style="color: white !important;"
                    >
                        Casos de Sucesso</a
                    >
                </li> -->
                <!-- <li class="mr-3">
                    <a
                        class="inline-block top-link text-black lg:text-gray-300 no-underline hover:text-gray-800 hover:text-underline py-2 px-4 link-click"
                        style="color: white !important;"
                        href="#nossos-servicos">Nossos Serviços</a
                    >
                </li> -->
                <!-- <li class="mr-3">
                    <a
                        class="inline-block top-link text-black lg:text-gray-300 no-underline hover:text-gray-800 hover:text-underline py-2 px-4 link-click"
                        style="color: white !important;"
                        href="#faq">FAQ</a
                    >
                </li> -->
                <li class="mr-3">
                    <a
                        class="inline-block top-link text-black lg:text-gray-300 no-underline hover:text-gray-800 hover:text-underline py-2 px-4 link-click"
                        style="color: white !important;"
                        href="/blog/">Blog</a
                    >
                </li>
                <li class="mr-3">
                    <a
                        class="inline-block top-link text-black lg:text-gray-300 no-underline hover:text-gray-800 hover:text-underline py-2 px-4 link-click"
                        style="color: white !important;"
                        href="https://fastvistos.com.br/formularios/">Formulários</a
                    >
                </li>
                <li class="mr-3">
                    <a
                        class="wpp_button_link inline-block top-link text-black lg:text-gray-300 no-underline hover:text-gray-800 hover:text-underline py-2 px-4"
                        style="color: white !important;"
                        data-linkcode="%231"
                        href="#">☎ (11) 5028-3044</a
                    >
                </li>
            </ul>
        </div>
    </div>
    <!-- <hr class="border-b border-gray-100 opacity-25 my-0 py-0" /> -->
</nav>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const navToggle = document.getElementById('nav-toggle');
        const navContent = document.getElementById('nav-content');
        if (navToggle && navContent) {
            navToggle.addEventListener('click', function () {
                navContent.classList.toggle('hidden');
            });
        }
    });
</script>

<style>
.site-name {
    font-size: 18px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    line-height: 1.2;
}

.site-operado {
    font-size: 9px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.2em;
    text-transform: uppercase;
}
</style>
