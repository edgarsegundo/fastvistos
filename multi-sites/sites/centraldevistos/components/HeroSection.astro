---
// Hero component — Central de Vistos
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;800&family=Inter:wght@400;500&display=swap');

  .hero-section {
    font-family: 'Sora', sans-serif;
  }

  /* ── gradient badge ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(8px);
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1rem;
  }

  /* ── slogan ── */
  .slogan {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    color: #fff;
    letter-spacing: -0.03em;
  }
  .slogan span {
    color: #FFD600;
  }

  /* ── subtitle ── */
  .subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.75);
    max-width: 480px;
    line-height: 1.6;
  }

  /* ── CTA ── */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFD600;
    color: #0A1628;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 12px;
    text-decoration: none;
    transition: transform 0.18s, box-shadow 0.18s;
    box-shadow: 0 4px 20px rgba(255,214,0,0.35);
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(255,214,0,0.5);
  }

  /* ── cover image ── */
  .cover-img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    object-fit: cover;
  }

  /* ── FLOW SECTION ── */
  .flow-section {
    background: #fff;
    padding: 60px 0 48px;
  }

  .flow-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0A1628;
    margin-bottom: 4px;
  }
  .flow-subtitle {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 800;
    color: #0A1628;
    margin-bottom: 40px;
  }
  .flow-subtitle em {
    font-style: normal;
    color: #1A56DB;
  }

  /* steps grid */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    position: relative;
  }

  /* connector line between steps */
  .steps-grid::before {
    content: '';
    position: absolute;
    top: 80px; /* center of the image */
    left: calc(10% + 16px);
    right: calc(10% + 16px);
    height: 2px;
    background: linear-gradient(90deg, #1A56DB 0%, #60A5FA 100%);
    z-index: 0;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 10px;
    position: relative;
    z-index: 1;
  }

  /* step image wrapper */
  .step-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    margin-bottom: 16px;
    position: relative;
    border: 3px solid #fff;
    outline: 2px solid #E2E8F0;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .step-img-wrap:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(26,86,219,0.18);
    outline-color: #1A56DB;
  }

  /* step number badge */
  .step-num {
    position: absolute;
    top: 10px;
    left: 10px;
    width: 28px;
    height: 28px;
    background: #1A56DB;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 800;
    font-size: 0.8rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .step-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .step-label {
    font-family: 'Sora', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #0A1628;
    line-height: 1.35;
    margin-bottom: 6px;
  }

  .step-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.90rem;
    color: #64748B;
    line-height: 1.5;
  }

  /* arrow between steps (hidden on mobile) */
  .step-arrow {
    position: absolute;
    right: -10px;
    top: 40px;
    color: #1A56DB;
    font-size: 1.1rem;
    z-index: 2;
  }

  /* last step highlight */
  .step:last-child .step-img-wrap {
    outline-color: #FFD600;
  }
  .step:last-child .step-num {
    background: #FFD600;
    color: #0A1628;
  }

  /* footer note */
  .flow-footer {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #94A3B8;
    text-align: center;
    margin-top: 32px;
  }
  .flow-footer strong {
    color: #1A56DB;
  }

  /* responsive */
  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .steps-grid::before { display: none; }
    .step-arrow { display: none; }
  }
  @media (max-width: 480px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>


<!-- ═══════════════════════════════════════
     HERO
════════════════════════════════════════ -->
<section class="hero-section pt-12 md:pt-4 relative overflow-hidden">

  <div class="container relative px-4 mx-auto flex flex-col items-center text-center gap-6 md:gap-8 pb-16">

    <!-- Badge + Título + Subtítulo -->
    <div class="flex flex-col items-center text-center w-full gap-0">

      <!-- Badge -->
      <div class="inline-flex items-center justify-center gap-2 bg-white/5 backdrop-blur-sm border border-white/30 text-white text-xs font-bold tracking-widest uppercase px-5 py-2 rounded-full mb-6">

        <!-- Dot -->
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#FF8A00] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#FF8A00]"></span>
        </span>

        Assessoria especializada
      </div>

      <!-- H1 -->
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-center w-full leading-none tracking-tight mb-6"
      style="
      font-family:'Sora',sans-serif;
      background: linear-gradient(90deg,#FF8A00,#FFC46B);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      ">
        VISTO FÁCIL
      </h1>

      <!-- Subtítulo -->
      <p class="text-lg md:text-2xl text-center text-white/90 w-full font-medium mb-8">
        Atendimento em todo o Brasil.
      </p>

      <!-- CTA -->
      <a href="#fale-conosco"
        class="inline-flex items-center justify-center gap-2 text-white font-bold text-lg md:text-xl px-10 py-4 rounded-2xl transition-all duration-300 hover:-translate-y-1"
        style="
        background: linear-gradient(135deg,#FF8A00,#FF6A00);
        box-shadow:0 12px 35px rgba(255,138,0,0.35);
        ">

        <!-- Ícone -->
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.52 3.48A12 12 0 0 0 3.48 20.52L2 22l1.48-1.48A12 12 0 1 0 20.52 3.48zM12 21a9 9 0 1 1 9-9 9 9 0 0 1-9 9zm4.95-6.39c-.27-.14-1.6-.79-1.85-.88s-.43-.14-.61.14-.7.88-.86 1.06-.32.2-.59.07a7.44 7.44 0 0 1-2.19-1.35 8.23 8.23 0 0 1-1.52-1.88c-.16-.27 0-.42.12-.56s.27-.32.41-.48a1.9 1.9 0 0 0 .27-.45.5.5 0 0 0 0-.48c-.07-.14-.61-1.47-.84-2s-.44-.46-.61-.47h-.52a1 1 0 0 0-.72.34 3.05 3.05 0 0 0-.95 2.27 5.29 5.29 0 0 0 1.1 2.8 12.13 12.13 0 0 0 4.64 4.11c.65.28 1.15.45 1.55.57a3.73 3.73 0 0 0 1.71.11 2.8 2.8 0 0 0 1.83-1.29 2.27 2.27 0 0 0 .16-1.29c-.07-.12-.25-.19-.52-.33z"/>
        </svg>

        Fale Conosco
      </a>

    </div>
  </div>
</section>



