---
// Hero component — Central de Vistos
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;800&family=Inter:wght@400;500&display=swap');

  .hero-section {
    font-family: 'Sora', sans-serif;
  }

  /* ── gradient badge ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(8px);
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1rem;
  }

  /* ── slogan ── */
  .slogan {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    color: #fff;
    letter-spacing: -0.03em;
  }
  .slogan span {
    color: #FFD600;
  }

  /* ── subtitle ── */
  .subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.75);
    max-width: 480px;
    line-height: 1.6;
  }

  /* ── CTA ── */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFD600;
    color: #0A1628;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 12px;
    text-decoration: none;
    transition: transform 0.18s, box-shadow 0.18s;
    box-shadow: 0 4px 20px rgba(255,214,0,0.35);
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(255,214,0,0.5);
  }

  /* ── cover image ── */
  .cover-img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    object-fit: cover;
  }

  /* ── FLOW SECTION ── */
  .flow-section {
    background: #fff;
    padding: 60px 0 48px;
  }

  .flow-title {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0A1628;
    margin-bottom: 4px;
  }
  .flow-subtitle {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 800;
    color: #0A1628;
    margin-bottom: 40px;
  }
  .flow-subtitle em {
    font-style: normal;
    color: #1A56DB;
  }

  /* steps grid */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    position: relative;
  }

  /* connector line between steps */
  .steps-grid::before {
    content: '';
    position: absolute;
    top: 80px; /* center of the image */
    left: calc(10% + 16px);
    right: calc(10% + 16px);
    height: 2px;
    background: linear-gradient(90deg, #1A56DB 0%, #60A5FA 100%);
    z-index: 0;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 10px;
    position: relative;
    z-index: 1;
  }

  /* step image wrapper */
  .step-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    margin-bottom: 16px;
    position: relative;
    border: 3px solid #fff;
    outline: 2px solid #E2E8F0;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .step-img-wrap:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(26,86,219,0.18);
    outline-color: #1A56DB;
  }

  /* step number badge */
  .step-num {
    position: absolute;
    top: 10px;
    left: 10px;
    width: 28px;
    height: 28px;
    background: #1A56DB;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 800;
    font-size: 0.8rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .step-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .step-label {
    font-family: 'Sora', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #0A1628;
    line-height: 1.35;
    margin-bottom: 6px;
  }

  .step-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    color: #64748B;
    line-height: 1.5;
  }

  /* arrow between steps (hidden on mobile) */
  .step-arrow {
    position: absolute;
    right: -10px;
    top: 40px;
    color: #1A56DB;
    font-size: 1.1rem;
    z-index: 2;
  }

  /* last step highlight */
  .step:last-child .step-img-wrap {
    outline-color: #FFD600;
  }
  .step:last-child .step-num {
    background: #FFD600;
    color: #0A1628;
  }

  /* footer note */
  .flow-footer {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #94A3B8;
    text-align: center;
    margin-top: 32px;
  }
  .flow-footer strong {
    color: #1A56DB;
  }

  /* responsive */
  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .steps-grid::before { display: none; }
    .step-arrow { display: none; }
  }
  @media (max-width: 480px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- ═══════════════════════════════════════
     HERO
════════════════════════════════════════ -->
<section class="hero-section pt-12 md:pt-4" style="background: linear-gradient(135deg, #0A1628 0%, #1A3A6B 60%, #1E4D8C 100%);">
  <div class="container px-4 mx-auto flex flex-wrap flex-col md:flex-row items-center gap-8 pb-16">

    <!-- Left Col -->
    <div class="flex flex-col w-full md:w-1/2 justify-center items-start text-center md:text-left">
      <div class="badge">
        <svg width="10" height="10" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4"/></svg>
        Assessoria especializada
      </div>

      <h1 class="slogan my-3">
        VISTO<br/><span>FÁCIL</span>
      </h1>

      <p class="subtitle mb-6">
        Passaporte na sua mão, visto no prazo certo.<br/>
        A Central de Vistos cuida de tudo para você.
      </p>

      <a href="#contato" class="cta-btn">
        Falar com especialista
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <!-- Right Col -->
    <div class="w-full md:w-1/2 text-center">
      <img
        class="cover-img"
        src="assets/images/cover/woman_cover.webp"
        alt="Visto fácil e rápido"
        loading="lazy"
      />
    </div>

  </div>
</section>

