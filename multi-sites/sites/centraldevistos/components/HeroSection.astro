---
// Hero component
---

<!-- HERO RESPONSIVO -->
<section class="relative h-[45vh] sm:h-[50vh] md:h-[55vh] lg:h-[60vh]">

<!-- Background -->
<div class="absolute inset-0">
    <img
    src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e"
    class="w-full h-full object-cover"
    alt=""
    >
    <div class="absolute inset-0 bg-black/35"></div>
</div>

<!-- Navbar -->
<header class="relative z-10 px-6 md:px-12 py-6 flex justify-between items-center text-white">

    <div class="text-2xl font-bold">
    VisaInfo
    </div>

    <nav class="hidden md:flex gap-8 text-sm font-medium">
    <a href="#">Países</a>
    <a href="#">Vistos</a>
    <a href="#">Contato</a>
    </nav>

</header>

<!-- Hero Text -->
<div class="relative z-10 flex flex-col justify-center items-center h-full text-center px-6 text-white">

    <h1 class="text-4xl md:text-6xl font-bold max-w-4xl">
    Descubra, <br class="block md:hidden">organize e <br class="block md:hidden">viaje
    <!-- Informe-se, <br class="block md:hidden">organize e <br class="block md:hidden">viaje -->
    <!-- Informe-se, <br class="block md:hidden">prepare-se e <br class="block md:hidden">viaje -->
    </h1>

    <p class="mt-4 text-lg md:text-2xl text-white/90 uppercase">
    Informações sobre vistos em um só lugar
    </p>

</div>

</section>

<!-- SEARCH SECTION -->
<section class="relative z-20 -mt-10 px-6 md:px-12">

<div class="max-w-4xl mx-auto">

    <!-- Search -->
    <div class="bg-white rounded-2xl px-6 py-5 flex items-center gap-4 border border-gray-200 shadow-lg">

    <span class="text-xl text-gray-400">🔍</span>

    <input
        type="text"
        placeholder="Buscar país..."
        class="bg-transparent outline-none w-full text-lg placeholder-gray-400"
    >

    </div>

    <!-- Filters -->
    <div class="flex gap-4 mt-8 justify-center flex-wrap">

    <button class="px-6 py-3 rounded-full border border-gray-300 text-gray-600">
        Todos
    </button>

    <button class="px-6 py-3 rounded-full bg-blue-600 text-white font-semibold">
        ⭐ Populares
    </button>

    <button class="px-6 py-3 rounded-full border border-gray-300 text-gray-600">
        Turismo
    </button>

    <button class="px-6 py-3 rounded-full border border-gray-300 text-gray-600">
        Estudo
    </button>

    </div>

</div>

</section>

<!-- LISTA -->
<section class="px-6 md:px-12 py-14">

<div class="max-w-4xl mx-auto space-y-5">

    <div class="bg-gray-50 border border-gray-200 rounded-3xl px-6 py-6 flex justify-between items-center hover:bg-gray-100 transition cursor-pointer">
    <div class="flex items-center gap-4 text-xl font-semibold">
        🇦🇺 Austrália
    </div>
    <span class="text-gray-400 text-2xl">›</span>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-3xl px-6 py-6 flex justify-between items-center hover:bg-gray-100 transition cursor-pointer">
    <div class="flex items-center gap-4 text-xl font-semibold">
        🇨🇦 Canadá
    </div>
    <span class="text-gray-400 text-2xl">›</span>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-3xl px-6 py-6 flex justify-between items-center hover:bg-gray-100 transition cursor-pointer">
    <div class="flex items-center gap-4 text-xl font-semibold">
        🇺🇸 Estados Unidos
    </div>
    <span class="text-gray-400 text-2xl">›</span>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-3xl px-6 py-6 flex justify-between items-center hover:bg-gray-100 transition cursor-pointer">
    <div class="flex items-center gap-4 text-xl font-semibold">
        🇵🇹 Portugal
    </div>
    <span class="text-gray-400 text-2xl">›</span>
    </div>

</div>

</section>



<style>
    .cta-button-wiggle {
        animation: wiggle 4s 2s infinite;
    }

    @keyframes wiggle {
        5%,
        50% {
            transform: scale(1);
        }
        10% {
            transform: scale(0.9);
        }
        15% {
            transform: scale(1.15);
        }
        20% {
            transform: scale(1.15) rotate(-5deg);
        }
        25% {
            transform: scale(1.15) rotate(5deg);
        }
        30% {
            transform: scale(1.15) rotate(-3deg);
        }
        35% {
            transform: scale(1.15) rotate(2deg);
        }
        40% {
            transform: scale(1.15) rotate(0);
        }
    }
</style>
