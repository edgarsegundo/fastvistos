<!-- ═══════════════════════════════════════
     COMO FUNCIONA  (flow section)
════════════════════════════════════════ -->
<section class="flow-section">
  <div class="container px-4 mx-auto">





    <div class="container mx-auto flex flex-wrap pt-4 pb-12">
        <h2
            class="w-full my-2 text-5xl font-bold leading-tight text-center text-gray-800"
            style="color: #1B375C;"
        >
            Como Funciona?
        </h2>
    </div>





    <div class="steps-grid">

      <!-- Step 1 -->
      <div class="step">
        <div class="step-img-wrap">
          <span class="step-num">1</span>
          <img src="assets/images/hero/freepik__a-professional-customer-support-specialist-wearing__1452.png" alt="Fale com um especialista" loading="lazy"/>
        </div>
        <p class="step-label">Fale com um especialista</p>
        <p class="step-desc">Nossa equipe orienta você passo a passo e coleta todas as informações.</p>
      </div>

      <!-- Step 2 -->
      <div class="step">
        <div class="step-img-wrap">
          <span class="step-num">2</span>
          <img src="assets/images/hero/freepik__a-photorealistic-logistics-scene-showing-an-intern__1453.png" alt="Envio seguro de documentos" loading="lazy"/>
        </div>
        <p class="step-label">Envio seguro de documentos</p>
        <p class="step-desc">Programamos a coleta do passaporte via <strong>Sedex</strong> com rastreamento.</p>
      </div>

      <!-- Step 3 -->
      <div class="step">
        <div class="step-img-wrap">
          <span class="step-num">3</span>
          <img src="assets/images/hero/freepik__a-photorealistic-office-scene-showing-a-profession__1454.png" alt="Equipe especializada acompanha" loading="lazy"/>
        </div>
        <p class="step-label">Equipe especializada acompanha</p>
        <p class="step-desc">Seu passaporte é recebido próximo aos consulados em São Paulo.</p>
      </div>

      <!-- Step 4 -->
      <div class="step">
        <div class="step-img-wrap">
          <span class="step-num">4</span>
          <img src="assets/images/hero/freepik__a-photorealistic-closeup-of-a-person-holding-a-mod__1455.png" alt="Acompanhamento em tempo real" loading="lazy"/>
        </div>
        <p class="step-label">Acompanhamento em tempo real</p>
        <p class="step-desc">Você recebe atualizações e suporte sempre que precisar.</p>
      </div>

      <!-- Step 5 — highlight -->
      <div class="step">
        <div class="step-img-wrap">
          <span class="step-num">5</span>
          <img src="assets/images/hero/freepik__the-attached-drawing-is-provided-only-as-a-visual-__1456.png" alt="Passaporte com visto pronto" loading="lazy"/>
        </div>
        <p class="step-label">Seu passaporte retorna com o visto pronto 🎉</p>
        <p class="step-desc">Com segurança e acompanhamento personalizado do início ao fim.</p>
      </div>

    </div>

  </div>
</section>