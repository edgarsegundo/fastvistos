---
// Voa Fred! - Landing Page
// Astro + Tailwind CSS
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Voa Fred! - Sonhos que Decolam</title>
  <meta name="description" content="Acompanhe a jornada do Fly Fred, um jovem de 13 anos apaixonado por aviação que sonha em se tornar piloto." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@700;800&family=Inter:wght@300;400;500;600;700&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --font-heading: 'Bricolage Grotesque', system-ui, sans-serif;
      --font-sans: 'Inter', system-ui, sans-serif;
      --font-body: 'Source Sans 3', system-ui, sans-serif;
    }
    html {
      scroll-behavior: smooth;
    }
    body {
      font-family: var(--font-sans);
    }
    .font-heading {
      font-family: var(--font-heading);
    }
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
    ::-webkit-scrollbar-thumb {
      background: #0ea5e9;
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #0284c7;
    }
  </style>
</head>
<body class="min-h-screen bg-white antialiased">
  <!-- Navigation Header -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-gradient-to-b from-black/60 to-transparent backdrop-blur-sm">
    <div class="container mx-auto px-4 py-3 lg:py-4">
      <div class="flex items-center justify-between">
        <!-- Logo / Brand -->
        <div class="flex items-center gap-3">
          <div class="relative">
            <img
              src="/images/hero/fred_com_uniforme_painted_trabalhando.png"
              alt="Fred, piloto campeão"
              class="w-11 h-11 md:w-14 md:h-14 rounded-full object-cover object-top border-2 border-white/80 shadow-lg"
            />
            <img
              src="/images/articles/biplane_transparent.png"
              alt=""
              class="absolute -right-2 -bottom-1 w-7 h-7 md:w-9 md:h-9 object-contain drop-shadow-md"
            />
          </div>
          <div>
            <h1 class="font-heading font-extrabold text-white text-lg md:text-2xl tracking-tight drop-shadow-md">
              Voa Fred!
            </h1>
            <p class="text-white/80 text-xs md:text-sm hidden sm:block">Sonhos que decolam</p>
          </div>
        </div>

        <!-- Social Links -->
        <nav class="flex items-center gap-3 md:gap-4">
          <a href="#redes" class="text-white/80 hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#redes" class="text-white/80 hover:text-white transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#redes" class="text-white/80 hover:text-white transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a href="#redes" class="text-white/80 hover:text-white transition-colors" aria-label="TikTok">
            <svg class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
            </svg>
          </a>
        </nav>
      </div>
    </div>
  </header>

  <!-- Hero Section - Compact -->
  <section class="relative min-h-[40vh] md:min-h-[35vh] lg:min-h-[30vh] w-full overflow-hidden flex items-center justify-center">
    <img
      src="/images/hero/imagem-ceu-principal-background-hero.jpg"
      class="absolute inset-0 w-full h-full object-cover"
      alt="Sky background"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/40"></div>
    <div class="relative z-10 text-center px-6 pt-16 pb-6">
      <p class="text-white text-base md:text-lg lg:text-xl max-w-2xl mx-auto leading-relaxed font-light drop-shadow-lg">
        "Eu ainda sou pequeno, mas o meu sonho de me tornar piloto é grande.
        Quem sonha alto, um dia decola."
      </p>
    </div>
  </section>

  <!-- Bento Grid - Main Content -->
  <section class="bg-white px-3 md:px-4 py-6 lg:py-8">
    <div class="container mx-auto max-w-7xl">
      <!-- Main Bento Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3 lg:gap-4 auto-rows-[minmax(120px,auto)]">
        
        <!-- About Card - Large -->
        <div class="col-span-2 md:col-span-2 lg:col-span-3 row-span-2 bg-gradient-to-br from-sky-50 to-sky-100/50 rounded-2xl p-5 lg:p-6 relative overflow-hidden shadow-sm">
          <div class="relative z-10 h-full flex flex-col">
            <h2 class="font-heading text-xl lg:text-2xl font-extrabold text-gray-900 mb-3">
              Oi, eu sou o Frederico!
            </h2>
            <div class="flex gap-3 mb-3">
              <img
                src="/images/articles/helicopero-fred-voo.jpeg"
                alt="Frederico no helicóptero"
                class="w-20 h-24 lg:w-24 lg:h-28 object-cover object-top flex-shrink-0 shadow-lg rounded-lg"
              />
              <div class="space-y-2 text-gray-700 text-sm leading-relaxed">
                <p>Mas muita gente me conhece como <strong class="text-gray-900">Fly Fred</strong>.</p>
                <p>Eu tenho 13 anos e o meu maior sonho é ser piloto de avião.</p>
              </div>
            </div>
            <div class="space-y-2 text-gray-700 text-sm leading-relaxed flex-1">
              <p>Eu estudo bastante, leio livros sobre aviação e também treino em simulador, como se já estivesse pilotando de verdade.</p>
              <p>Nas minhas redes sociais, onde já tenho mais de <strong class="text-gray-900">35.000 seguidores</strong>, compartilho minha rotina e tudo que aprendo.</p>
            </div>
          </div>
        </div>

        <!-- Fred Uniform Image -->
        <div class="col-span-1 lg:col-span-1 row-span-2 bg-gray-100 rounded-2xl overflow-hidden shadow-sm">
          <img
            src="/images/articles/fred-com-uniforme.jpeg"
            alt="Fred com uniforme de piloto"
            class="w-full h-full object-cover object-top"
          />
        </div>

        <!-- Chapter 1 Card -->
        <div class="col-span-1 lg:col-span-2 row-span-1 bg-sky-500 rounded-2xl p-4 flex flex-col justify-center shadow-sm">
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-white text-sky-500 font-bold text-sm">1</span>
            <h3 class="font-heading text-white font-extrabold text-base lg:text-lg">
              Como tudo começa
            </h3>
          </div>
          <p class="text-white/90 text-xs lg:text-sm leading-relaxed">
            Enquanto outras crianças pediam fantasias de super-herói, eu só queria um uniforme de piloto.
          </p>
        </div>

        <!-- Cockpit Image -->
        <div class="col-span-1 lg:col-span-2 row-span-1 bg-gray-100 rounded-2xl overflow-hidden shadow-sm">
          <img
            src="/images/articles/cockpit_junto_comandante.jpeg"
            alt="Fred no cockpit com o comandante"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Video Card 1 - Primeiro Voo -->
        <div class="col-span-1 lg:col-span-2 row-span-1 relative bg-gray-900 rounded-2xl overflow-hidden shadow-sm group cursor-pointer">
          <img
            src="/images/articles/biplane_transparent.png"
            alt="Primeiro voo"
            class="w-full h-full object-cover opacity-80"
          />
          <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/30 transition-colors">
            <div class="w-10 h-10 lg:w-12 lg:h-12 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
              <svg class="w-4 h-4 lg:w-5 lg:h-5 text-gray-900 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
          <span class="absolute bottom-2 left-2 text-white text-xs font-medium bg-black/60 px-2 py-1 rounded-full">
            Primeiro Voo
          </span>
        </div>

        <!-- Chapter 2 Card -->
        <div class="col-span-1 md:col-span-2 lg:col-span-2 row-span-1 bg-gray-100 rounded-2xl p-4 flex flex-col justify-center shadow-sm">
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-gray-900 text-white font-bold text-sm">2</span>
            <h3 class="font-heading text-gray-900 font-extrabold text-base lg:text-lg">
              Sonhar Alto!
            </h3>
          </div>
          <p class="text-gray-600 text-xs lg:text-sm leading-relaxed">
            Percebi que não era apenas admiração de infância; era um interesse que sempre voltava.
          </p>
        </div>

        <!-- CT Azul Card -->
        <div class="col-span-1 md:col-span-2 lg:col-span-2 row-span-1 relative bg-sky-600 rounded-2xl overflow-hidden shadow-sm">
          <div 
            class="absolute inset-0 opacity-30 bg-cover bg-center"
            style="background-image: url('/images/articles/embraer-195-azul.webp');"
          ></div>
          <div class="relative z-10 p-4 h-full flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-2">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-white text-sky-600 font-bold text-sm">3</span>
              <h3 class="font-heading text-white font-extrabold text-base lg:text-lg">
                CT da Azul
              </h3>
            </div>
            <p class="text-white/90 text-xs lg:text-sm leading-relaxed">
              Uma experiência incrível no centro de treinamento da Azul.
            </p>
          </div>
        </div>

        <!-- CT Images -->
        <div class="col-span-1 row-span-1 bg-gray-100 rounded-2xl overflow-hidden shadow-sm">
          <img
            src="/images/articles/conhecendo_o_ct_1.jpeg"
            alt="Conhecendo o CT da Azul"
            class="w-full h-full object-cover"
          />
        </div>

        <div class="col-span-1 row-span-1 bg-gray-100 rounded-2xl overflow-hidden shadow-sm">
          <img
            src="/images/articles/conhecendo_o_ct_2.jpeg"
            alt="Experiência no CT da Azul"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Video Card 2 - CT Azul Experience -->
        <div class="col-span-2 md:col-span-2 lg:col-span-3 row-span-1 relative bg-gray-900 rounded-2xl overflow-hidden shadow-sm group cursor-pointer">
          <img
            src="/images/articles/embraer-195-azul.webp"
            alt="Experiência CT Azul"
            class="w-full h-full object-cover opacity-70"
          />
          <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/30 transition-colors">
            <div class="w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
              <svg class="w-5 h-5 lg:w-6 lg:h-6 text-gray-900 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
          <span class="absolute bottom-3 left-3 text-white text-sm font-medium bg-black/60 px-3 py-1.5 rounded-full">
            Experiência no CT Azul
          </span>
        </div>

        <!-- Final Quote -->
        <div class="col-span-2 md:col-span-2 lg:col-span-3 row-span-1 bg-gradient-to-br from-sky-50 to-white rounded-2xl p-5 flex flex-col justify-center shadow-sm">
          <p class="text-gray-900 text-sm lg:text-base font-medium leading-relaxed">
            "Eu ainda tenho muito pra aprender, mas eu nunca vou desistir do meu sonho. Um dia eu vou estar lá em cima, pilotando um avião de verdade."
          </p>
          <p class="text-gray-500 text-xs mt-2">- Fly Fred</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Media Section - Very Prominent -->
  <section id="redes" class="bg-gray-900 py-10 lg:py-14">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-6 lg:mb-8">
        <h2 class="font-heading text-2xl lg:text-4xl font-extrabold text-white mb-2">
          Acompanhe essa jornada!
        </h2>
        <p class="text-gray-400 text-sm lg:text-base">
          Siga o Fly Fred em todas as redes sociais
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 lg:gap-4 max-w-3xl mx-auto">
        <!-- Facebook -->
        <a 
          href="#" 
          class="group flex flex-col items-center justify-center bg-blue-600 hover:bg-blue-700 rounded-2xl p-5 lg:p-6 transition-all hover:scale-105 shadow-lg"
        >
          <svg class="w-10 h-10 lg:w-12 lg:h-12 text-white mb-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span class="text-white font-bold text-sm lg:text-base">Facebook</span>
          <span class="text-white/70 text-xs">@flyfred</span>
        </a>

        <!-- Instagram -->
        <a 
          href="#" 
          class="group flex flex-col items-center justify-center bg-gradient-to-br from-purple-600 via-pink-600 to-orange-500 hover:from-purple-700 hover:via-pink-700 hover:to-orange-600 rounded-2xl p-5 lg:p-6 transition-all hover:scale-105 shadow-lg"
        >
          <svg class="w-10 h-10 lg:w-12 lg:h-12 text-white mb-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <span class="text-white font-bold text-sm lg:text-base">Instagram</span>
          <span class="text-white/70 text-xs">@flyfred</span>
        </a>

        <!-- TikTok -->
        <a 
          href="#" 
          class="group flex flex-col items-center justify-center bg-black hover:bg-gray-800 rounded-2xl p-5 lg:p-6 transition-all hover:scale-105 border border-gray-700 shadow-lg"
        >
          <svg class="w-10 h-10 lg:w-12 lg:h-12 text-white mb-2" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
          </svg>
          <span class="text-white font-bold text-sm lg:text-base">TikTok</span>
          <span class="text-gray-400 text-xs">@flyfred</span>
        </a>

        <!-- YouTube -->
        <a 
          href="#" 
          class="group flex flex-col items-center justify-center bg-red-600 hover:bg-red-700 rounded-2xl p-5 lg:p-6 transition-all hover:scale-105 shadow-lg"
        >
          <svg class="w-10 h-10 lg:w-12 lg:h-12 text-white mb-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span class="text-white font-bold text-sm lg:text-base">YouTube</span>
          <span class="text-white/70 text-xs">@flyfred</span>
        </a>
      </div>

      <!-- Follower Count -->
      <div class="text-center mt-8">
        <div class="inline-flex items-center gap-2 bg-yellow-400 text-gray-900 font-bold text-base lg:text-lg px-5 py-2.5 rounded-full shadow-lg">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
          +35.000 seguidores
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-950 py-4">
    <div class="container mx-auto px-4 text-center">
      <p class="text-gray-500 text-xs">
        Fly Fred - Sonhos que decolam
      </p>
    </div>
  </footer>
</body>
</html>