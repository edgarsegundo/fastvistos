// custom-video overlay (existente)
document.querySelectorAll('.custom-video').forEach((video, i) => {
    const overlay = document.querySelectorAll('.custom-overlay')[i];
    if (video && overlay) {
        overlay.addEventListener('click', function() {
            overlay.style.opacity = '0';
            setTimeout(() => overlay.style.display = 'none', 200);
            video.play();
        });
        video.addEventListener('pause', function() {
            if (video.currentTime < video.duration) {
                overlay.style.display = 'flex';
                setTimeout(() => overlay.style.opacity = '1', 10);
            }
        });
        video.addEventListener('ended', function() {
            overlay.style.display = 'flex';
            setTimeout(() => overlay.style.opacity = '1', 10);
            video.currentTime = 0;
        });
    }
});



</script>


<script>
// Animação do avião com deslocamento real usando keyframes
(function() {
    const canvas = document.getElementById('plane-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    const FPS = 25;
    const images = [];
    let keyframes = [];
    let loaded = 0;
    let currentFrame = 0;
    let TOTAL_FRAMES = 0;
    let animating = false;

    function resize() {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize);


    // Carrega keyframes e sprite sheet JSON
    Promise.all([
        fetch('assets/videos/plane-keyframes-reduced.json').then(r => r.json()),
        fetch('assets/videos/plane-sprite-optimized.json').then(r => r.json())
    ]).then(([keyframesData, spriteData]) => {
        keyframes = keyframesData;
        TOTAL_FRAMES = spriteData.frames.length;
        loadSprite(spriteData);
    });

    let spriteImg, spriteFrames;
    function loadSprite(spriteData) {
        spriteImg = new Image();
        spriteImg.src = 'assets/videos/plane-sprite-optimized.png';
        spriteFrames = spriteData.frames;
        spriteImg.onload = () => startAnimation();
    }


    function startAnimation() {
        animating = true;
        let lastTime = 0;
        const interval = 1000 / FPS;

        // Bounding box para centralizar
        let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
        for (const kf of keyframes) {
            if (kf.x < minX) minX = kf.x;
            if (kf.x > maxX) maxX = kf.x;
            if (kf.y < minY) minY = kf.y;
            if (kf.y > maxY) maxY = kf.y;
        }
        const ZOOM = 60;
        const trajCenterX = (minX + maxX) / 2;
        const trajCenterY = (minY + maxY) / 2;

        function animate(now) {
            if (!animating) return;
            if (!lastTime) lastTime = now;
            if (now - lastTime >= interval) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                const kf = keyframes[currentFrame];
                const frame = spriteFrames[currentFrame];
                const centerX = canvas.width / 2;
                const centerY = canvas.height / 2;
                const px = centerX + (kf.x - trajCenterX) * ZOOM;
                const py = centerY + (kf.y - trajCenterY) * ZOOM;
                const SCALE_FIX = 4;
                const baseSize = canvas.height * 0.28;
                const imgW = baseSize * (kf.scale || 1) * SCALE_FIX;
                const imgH = baseSize * (kf.scale || 1) * SCALE_FIX;
                ctx.drawImage(
                    spriteImg,
                    frame.x, frame.y, frame.width, frame.height, // src
                    px - imgW / 2, py - imgH / 2, imgW, imgH      // dest
                );
                currentFrame = (currentFrame + 1) % TOTAL_FRAMES;
                lastTime = now;
            }
            requestAnimationFrame(animate);
        }
        requestAnimationFrame(animate);
    }
})();

</script>


