---
import SharedHomeLayout from '../layouts/SharedHomeLayout.astro';
import { siteConfig } from '../site-config.ts';
import JsonLdHomePageBase from '../components/JsonLdHomePageBase.astro';

const { bodyClass = '', bodyStyle = '' } = Astro.props;
---

<SharedHomeLayout
    themeToggleDisable={true}
    bodyClass={`${bodyClass} leading-normal tracking-normal antialiased`}
    bodyStyle={`${bodyStyle} font-family: 'Source Sans Pro', sans-serif;`}
    canonicalConf={siteConfig.site.canonical}
    faviconPathFromConf={siteConfig.site.faviconPath}
    seoFromConf={siteConfig.homePageConfig.seo}
    titleFromConf={siteConfig.homePageConfig.seo.title}
    descriptionFromConf={siteConfig.homePageConfig.seo.description}
    authorNameFromConf={siteConfig.site.authorName}
    imageFromConf={null}
    imageUrlFromConf={siteConfig.site.primaryImage.url}
    imageCaptionFromConf={siteConfig.site.primaryImage.imageCaption}
    imageWidthFromConf={siteConfig.site.primaryImage.imageWidth}
    imageHeightFromConf={siteConfig.site.primaryImage.imageHeight}
>
    <Fragment slot="head">
        <link rel="preload" href="/assets/fonts/bricolage.woff2" as="font" type="font/woff2" crossorigin>
        <JsonLdHomePageBase
            faqList={[]}
            servicesList={[]}
            reviewsList={[]}
            disableReviews={false}
        />
    </Fragment>

    <div class="bg-white" style="margin: 6px;">
        <!-- ═══════════ HERO ═══════════ -->
        <section class="relative w-full overflow-hidden min-h-[400px] xl:min-h-[380px]">

            <!-- BG: céu -->
            <img
                src="assets/images/hero/imagem-ceu-principal-background-hero.jpg"
                class="absolute inset-0 w-full h-full object-cover"
                alt="Sky background"
            >

            <!-- Substitui o <video> por canvas -->
            <canvas
                id="plane-canvas"
                class="absolute inset-0 pointer-events-none z-20"
                style="width:100%;height:100%;"
            ></canvas>


            <!-- Plano de animação (mantido caso precise) -->
            <div id="plane-layer" class="absolute inset-0 z-20 pointer-events-none"></div>

            <!-- ── NAV TOPO ── -->
            <nav class="relative z-30 flex items-center justify-between px-6 xl:px-20 pt-6 pb-2">
                <span class="font-agrandir text-black text-xl font-extrabold tracking-tight opacity-90">&nbsp;</span>
                <div class="flex items-center gap-5">
                    <!-- Ícones redes sociais em preto -->
                    <a href="#" aria-label="Facebook" class="hidden text-black/70 hover:text-black transition-colors">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                        </svg>
                    </a>
                    <a href="https://www.instagram.com/fly_fred1" aria-label="Instagram" class="text-black/70 hover:text-black transition-colors">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                            <circle cx="12" cy="12" r="4"/>
                            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                        </svg>
                    </a>
                    <a href="https://www.youtube.com/@flyfred-u9n" aria-label="YouTube" class="text-black/70 hover:text-black transition-colors">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58a2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor"/>
                        </svg>
                    </a>
                    <a href="https://www.tiktok.com/@flyfred3d" aria-label="TikTok" class="text-black/70 hover:text-black transition-colors">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.77 1.52V6.76a4.85 4.85 0 0 1-1-.07z"/>
                        </svg>
                    </a>
                </div>
            </nav>

            <!-- ── CONTEÚDO HERO ── -->
            <!-- <div class="relative z-10 flex flex-col xl:flex-row xl:items-start xl:justify-between px-6 xl:px-20 pt-6 xl:pt-8 pb-10 xl:pb-14 gap-6 xl:gap-0">
                <div class="flex flex-row xl:flex-col items-center xl:items-start gap-4">
                    <img
                        src="assets/images/hero/fred_com_uniforme_painted_trabalhando.png"
                        alt="Fred, piloto campeão"
                        class="hero-avatar w-20 h-20 xl:w-36 xl:h-36 rounded-full object-cover object-top border-2 border-black ring-[2px] ring-black/20 flex-shrink-0"
                    />
                    <div class="relative">
                        <div class="relative p-2">
                            <p class="text-black text-sm xl:text-base uppercase tracking-widest opacity-90 mb-1" style="text-shadow: 1px 1px 3px rgba(255,255,255,0.5);">
                                · Piloto em formação
                            </p>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col items-start xl:items-end text-left xl:text-right xl:max-w-2xl">
                    <h1 class="font-agrandir text-black hero-title leading-none font-extrabold" style="text-shadow: 2px 2px 4px rgba(255,255,255,0.5);">
                        Voa Fred!
                    </h1>
                    <p class="mt-4 max-w-lg text-black text-base xl:text-xl leading-relaxed" style="text-shadow: 1px 1px 3px rgba(255,255,255,0.5);">
                        "Eu ainda sou pequeno, mas o meu sonho de me tornar piloto é grande.
                        Quem sonha alto, um dia decola."
                    </p>
                </div>
            </div> -->

            


            <div class="relative z-10 flex flex-col xl:flex-row xl:items-start xl:justify-between px-6 xl:px-20 pt-6 xl:pt-8 pb-10 xl:pb-14 gap-6 xl:gap-0">
                <!-- Esquerda: avatar pequeno + badge -->
                <div class="flex flex-row xl:flex-col items-center xl:items-start gap-4">
                    <img
                        src="assets/images/hero/c57b9b7c-7a74-459c-b070-f3b0041a1bed.png"
                        alt="Fred, piloto campeão"
                        class="w-20 h-20 xl:w-36 xl:h-36 flex-shrink-0"
                    />
                    <div class="relative">
                        <div class="relative p-2">
                            <p class="text-black text-sm xl:text-base uppercase tracking-widest opacity-90 mb-1" style="text-shadow: 1px 1px 3px rgba(255,255,255,0.5);">
                                · Piloto em formação
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Direita: título + frase + CTA -->
                <div class="flex flex-col items-start xl:items-end text-left xl:text-right xl:max-w-2xl">
                    <h1 class="font-agrandir text-black hero-title leading-none font-extrabold" style="text-shadow: 2px 2px 4px rgba(255,255,255,0.5);">
                        Voa Fred!
                    </h1>
                    <p class="mt-4 max-w-lg text-black text-base xl:text-xl leading-relaxed" style="text-shadow: 1px 1px 3px rgba(255,255,255,0.5);">
                        "Eu ainda sou pequeno, mas o meu sonho de me tornar piloto é grande.
                        Quem sonha alto, um dia decola."
                    </p>
                </div>
            </div>



            <!-- Fundo fade para o branco -->
            <div class="hero-fade-bottom absolute bottom-0 left-0 right-0 h-16 xl:h-20 pointer-events-none"></div>
        </section>

        <!-- ═══════════ SOBRE ═══════════ -->
        <section id="sobre" class="relative bg-white overflow-hidden px-6 xl:px-20 py-16 xl:py-12">

            <!-- <img
                src="./images/details/sky_clouds_trabalhando.svg"
                class="absolute bottom-0 left-0 w-full h-64 object-cover object-top opacity-20 pointer-events-none"
                alt=""
            > -->


            <div class="absolute bottom-0 left-0 w-full h-64 pointer-events-none" style="
                background: url('./images/details/sky_clouds_trabalhando.svg') center top / cover no-repeat;
                opacity: 0.2;
                mask-image: linear-gradient(
                    to bottom,
                    rgba(0,0,0,0) 0%,
                    rgba(0,0,0,0) 18%,
                    rgba(0,0,0,0.01) 28%,
                    rgba(0,0,0,0.03) 38%,
                    rgba(0,0,0,0.07) 48%,
                    rgba(0,0,0,0.14) 58%,
                    rgba(0,0,0,0.26) 68%,
                    rgba(0,0,0,0.45) 78%,
                    rgba(0,0,0,0.68) 88%,
                    rgba(0,0,0,0.88) 95%,
                    rgba(0,0,0,1) 100%
                );
                -webkit-mask-image: linear-gradient(
                    to bottom,
                    rgba(0,0,0,0) 0%,
                    rgba(0,0,0,0) 18%,
                    rgba(0,0,0,0.01) 28%,
                    rgba(0,0,0,0.03) 38%,
                    rgba(0,0,0,0.07) 48%,
                    rgba(0,0,0,0.14) 58%,
                    rgba(0,0,0,0.26) 68%,
                    rgba(0,0,0,0.45) 78%,
                    rgba(0,0,0,0.68) 88%,
                    rgba(0,0,0,0.88) 95%,
                    rgba(0,0,0,1) 100%
                );
            "></div>


            <div class="relative z-10 w-full">

                <!-- Topo: título full-width -->
                <div class="flex items-start justify-between gap-4 mb-10 xl:mb-16 -mt-12 xl:-mt-4">
                    <h2 class="font-agrandir text-black text-3xl xl:text-5xl leading-tight font-extrabold" style="word-spacing: -0.1em;">
                        Oi, eu sou o Frederico!
                    </h2>
                    <!-- Foto só mobile -->
                    <img
                        src="assets/images/articles/helicopero-fred-voo.jpeg"
                        alt="Frederico no helicóptero"
                        class="block xl:hidden w-24 h-28 object-cover object-top flex-shrink-0"
                        style="box-shadow: 0 4px 16px rgba(0,0,0,0.15);"
                    >
                </div>

                <!-- Grid 12 colunas desktop -->
                <div class="flex flex-col xl:grid xl:grid-cols-12 xl:gap-10 xl:items-start">

                    <!-- Col 1-4: bloco texto esquerdo -->
                    <div class="xl:col-span-4 flex flex-col gap-5">
                        <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                            Mas muita gente me conhece como <strong class="text-black">Fly Fred</strong>.
                        </p>
                        <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                            Tenho 13 anos e o maior sonho da minha vida é ser piloto de avião. Desde muito pequeno eu sou apaixonado por aviões — não só pela beleza deles, mas pela liberdade que eles representam.
                        </p>
                        <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                            Estudo bastante, leio livros sobre aviação e treino em simulador como se já estivesse pilotando de verdade. Quero entender cada botão, cada instrumento, cada fase de voo.
                        </p>
                    </div>

                    <!-- Col 5-8: foto grande — só desktop -->
                    <div class="hidden xl:block xl:col-span-4">
                        <img
                            src="assets/images/articles/helicopero-fred-voo.jpeg"
                            alt="Frederico no helicóptero"
                            class="w-full h-full object-cover object-top"
                            style="box-shadow: 0 8px 32px rgba(0,0,0,0.15); max-height: 520px;"
                        >
                    </div>

                    <!-- Col 9-12: bloco texto direito -->
                    <div class="xl:col-span-4 flex flex-col gap-5 mt-8 xl:mt-0">
                        <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                            Uma das coisas mais incríveis que já me aconteceu foi ser convidado para conhecer o CT de treinamento da Azul. Também já fiz voo de acrobacia — uma experiência que nunca vou esquecer.
                        </p>
                        <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                            Estudo inglês todo dia, porque sei que é essencial pra quem quer ser piloto. Nas minhas redes sociais, onde já tenho mais de <strong>35.000 seguidores</strong>, compartilho minha rotina, meus estudos e tudo que aprendo nesse caminho.
                        </p>
                        <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                            Ainda tenho muito pela frente. Mas nunca vou desistir. Um dia eu vou estar lá em cima, pilotando de verdade.
                        </p>
                    </div>

                </div>
            </div>
        </section>

        <!-- ═══════════ CARD 1 — Como tudo começa ═══════════ -->
        <section class="relative w-full">
            <article class="story-card relative card-sky overflow-hidden mb-6 px-6 xl:px-20 py-0" data-chapter="1">

                <div class="relative z-10 w-full flex flex-col">

                    <!-- Header com background sky -->
                    <div class="relative overflow-hidden flex flex-col justify-end px-6 xl:px-20 -mx-6 xl:-mx-20 mb-10 min-h-[220px] xl:min-h-[420px]">
                        <div style="position:absolute;top:0;left:0;width:100%;height:100%;background:url('assets/images/articles/ceu-e-nuvens-reais.jpg') center/cover no-repeat;mask-image:linear-gradient(to bottom,rgba(0,0,0,1) 0%,rgba(0,0,0,0.9) 60%,rgba(0,0,0,0) 100%);-webkit-mask-image:linear-gradient(to bottom,rgba(0,0,0,1) 0%,rgba(0,0,0,0.9) 60%,rgba(0,0,0,0) 100%);z-index:0;"></div>
                        <div style="position:absolute;top:0;left:0;width:100%;height:50%;background:url('assets/images/articles/biplane_transparent.png') center/cover no-repeat;opacity:0.85;mix-blend-mode:multiply;mask-image:linear-gradient(to bottom,rgba(0,0,0,1) 0%,rgba(0,0,0,0.8) 60%,rgba(0,0,0,0) 100%);-webkit-mask-image:linear-gradient(to bottom,rgba(0,0,0,1) 0%,rgba(0,0,0,0.8) 60%,rgba(0,0,0,0) 100%);z-index:1;"></div>

                        <div class="relative" style="z-index:10;">
                            <svg class="mb-4 xl:mb-10" width="56" height="56" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
                                <defs><mask id="number-cut"><rect width="40" height="40" fill="white"/><text x="20" y="27" text-anchor="middle" font-size="20" font-family="Agrandir, sans-serif" font-weight="bold" fill="black">1</text></mask></defs>
                                <circle cx="20" cy="20" r="20" fill="white" mask="url(#number-cut)"/>
                            </svg>
                            <h2 class="font-agrandir-white-shadow text-4xl xl:text-7xl leading-[0.95] font-extrabold pb-8">
                                Como tudo <br>começa
                            </h2>
                        </div>
                    </div>

                    <!-- Row única: imagem1 | texto | imagem2 -->
                    <div class="flex flex-col xl:flex-row xl:gap-10 xl:items-start pb-0 xl:pb-20">

                        <!-- Imagem 1 -->
                        <div class="xl:w-1/4 flex-shrink-0 mt-0 xl:mt-0">
                            <img
                                src="assets/images/articles/fred-com-uniforme.jpeg"
                                alt="Fred com uniforme de piloto"
                                class="w-full block"
                                style="height:auto;object-fit:cover;"
                            >
                        </div>

                        <!-- Texto central -->
                        <div class="xl:flex-1 flex flex-col gap-6 mt-8 xl:mt-0">
                            <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                                Enquanto a maioria das crianças pedia fantasias de super-herói, eu só queria uma coisa: um uniforme de piloto. Era meu de todo jeito — no Carnaval, no aniversário, no dia-a-dia. Minha mãe ainda guarda a foto.
                            </p>
                            <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                                Com o tempo, percebi que não era admiração de infância passageira. Era um interesse que voltava sempre — como se desde cedo alguma parte de mim já soubesse qual caminho queria seguir.
                            </p>
                            <p class="font-dark-shadow text-xl xl:text-2xl leading-[1.45]">
                                Aos 7 anos ganhei meu primeiro livro sobre aviação — e li do começo ao fim sem parar. Meu pai disse que foi a primeira vez que me viu quieto por tanto tempo. A paixão estava ali, esperando só crescer junto comigo.
                            </p>

                        <!-- <img
                            src="assets/images/articles/cockpit_junto_comandante.jpeg"
                            alt="Fred no cockpit com o comandante"
                            class="w-full block"
                            style="height:auto;object-fit:cover;"
                        > -->

                        </div>

                        <!-- Imagem 2 -->
                        <!-- <div class="xl:w-1/4 flex-shrink-0 mt-8 xl:mt-0">
                            <img
                                src="assets/images/articles/cockpit_junto_comandante.jpeg"
                                alt="Fred no cockpit com o comandante"
                                class="w-full block"
                                style="height:auto;object-fit:cover;"
                            >
                        </div> -->


                        <!-- Imagem 2 -->
                        <div class="xl:w-1/4 flex-shrink-0 mt-8 xl:mt-0 flex flex-col">
                            <!-- Segunda imagem abaixo -->
                            <img
                                src="assets/images/articles/cockpit2.jpeg"
                                alt="Fred preparando voo" 
                                class="w-full block mt-6"
                                style="height:auto;object-fit:cover;"
                            >
                        </div>
                    </div>
                </div>
            </article>
        </section>

        <!-- ═══════════ CARD 2 — Comece a Sonhar Alto ═══════════ -->
        <section class="relative w-full">
            <article class="story-card relative card-sky-white-bg overflow-hidden -mt-22 xl:-mt-84 mb-6 xl:mb-12 px-6 xl:px-20 py-0" data-chapter="2">

                <div class="relative z-10 w-full flex flex-col">

                    <!-- Header -->
                    <div class="relative flex flex-col justify-end px-6 xl:px-20 -mx-6 xl:-mx-20 mb-10 min-h-[280px] xl:min-h-[420px]">
                        <div style="position:absolute;top:0;right:-2rem;width:55%;height:100%;background:url('assets/images/articles/ceu_nuvem_separada.png') center/contain no-repeat;mask-image:linear-gradient(to right,rgba(0,0,0,1) 0%,rgba(0,0,0,0.95) 20%,rgba(0,0,0,0.85) 40%,rgba(0,0,0,0.6) 55%,rgba(0,0,0,0.3) 70%,rgba(0,0,0,0.1) 85%,rgba(0,0,0,0) 100%),linear-gradient(to bottom,rgba(0,0,0,0.9) 0%,rgba(0,0,0,0.9) 60%,rgba(0,0,0,0) 100%);-webkit-mask-image:linear-gradient(to right,rgba(0,0,0,1) 0%,rgba(0,0,0,0.95) 20%,rgba(0,0,0,0.85) 40%,rgba(0,0,0,0.6) 55%,rgba(0,0,0,0.3) 70%,rgba(0,0,0,0.1) 85%,rgba(0,0,0,0) 100%);mask-composite:intersect;-webkit-mask-composite:destination-in;z-index:0;"></div>

                        <div class="relative" style="z-index:10;">
                            <svg class="mb-6 xl:mb-10" width="56" height="56" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="20" cy="20" r="20" fill="black"/>
                                <text x="20" y="27" text-anchor="middle" font-size="20" fill="white" font-family="Agrandir, sans-serif" font-weight="bold">2</text>
                            </svg>
                            <h2 class="font-agrandir text-black text-4xl xl:text-7xl leading-[0.95] font-extrabold pb-8">
                                Comece a<br>Sonhar Alto!
                            </h2>
                        </div>
                    </div>

                    <!-- Row única: texto | imagem | vídeo -->
                    <div class="flex flex-col xl:flex-row xl:gap-10 xl:items-stretch mb-12 xl:mb-20">

                        <!-- Coluna 1: texto -->
                        <div class="xl:w-1/3 flex-shrink-0 flex flex-col gap-4 -mt-4 xl:mt-0">
                            <p class="font-dark-shadow text-2xl xl:text-3xl leading-[1.35]">
                                Sonhar alto não é só uma frase bonita. É acordar cedo pra estudar antes da escola. É assistir a documentários sobre aviação quando todo mundo tá vendo outra coisa. É treinar no simulador mesmo quando cansa.
                            </p>
                            <p class="font-dark-shadow text-2xl xl:text-3xl leading-[1.35]">
                                O meu primeiro voo sozinho no simulador foi um momento que nunca vou esquecer. Tremi um pouco na decolagem — mas quando o nariz subiu, eu senti que era isso. Era exatamente isso que eu queria fazer pelo resto da vida.
                            </p>
                            <p class="font-dark-shadow text-2xl xl:text-3xl leading-[1.35]">
                                Hoje eu entendo que o sonho não espera você estar pronto. Ele cresce junto com você — a cada livro lido, a cada hora de inglês, a cada voo no simulador. O segredo é não parar.
                            </p>
                        </div>

                        <!-- Coluna 2: imagem -->
                        <div class="xl:w-1/3 flex-shrink-0 mt-8 xl:mt-0">
                            <img
                                src="assets/images/articles/helicopetero.jpeg"
                                alt="Fred no helicóptero"
                                class="w-full block h-full object-cover"
                                style="aspect-ratio: 4/3;"
                            >
                        </div>

                        <!-- Coluna 3: vídeo -->
                        <div class="xl:w-1/3 flex-shrink-0 mt-8 xl:mt-0 relative">
                            <video
                                src="assets/videos/primeiro_voo.mp4"
                                class="w-full block h-full custom-video"
                                style="object-fit: cover;"
                                playsinline
                            ></video>
                            <div class="custom-overlay absolute inset-0 flex items-center justify-center bg-black/30 cursor-pointer transition-opacity duration-200 z-20">
                                <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="36" cy="36" r="36" fill="rgba(0,0,0,0.55)"/>
                                    <polygon points="28,22 54,36 28,50" fill="#fff"/>
                                </svg>
                            </div>
                        </div>

                    </div>

                </div>
            </article>

            <!-- <img
                src="assets/images/articles/ceu_nuvem_esquerda.png"
