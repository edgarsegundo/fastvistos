---
import SharedHomeLayout from '../layouts/SharedHomeLayout.astro';
import { siteConfig } from '../site-config.ts';
import JsonLdHomePageBase from '../components/JsonLdHomePageBase.astro';

const { bodyClass = '', bodyStyle = '' } = Astro.props;
---

<SharedHomeLayout
    themeToggleDisable={true}
    bodyClass={`${bodyClass} leading-normal tracking-normal antialiased`}
    bodyStyle={`${bodyStyle} font-family: 'Source Sans Pro', sans-serif;`}
    canonicalConf={siteConfig.site.canonical}
    faviconPathFromConf={siteConfig.site.faviconPath}
    seoFromConf={siteConfig.homePageConfig.seo}
    titleFromConf={siteConfig.homePageConfig.seo.title}
    descriptionFromConf={siteConfig.homePageConfig.seo.description}
    authorNameFromConf={siteConfig.site.authorName}
    imageFromConf={null}
    imageUrlFromConf={siteConfig.site.primaryImage.url}
    imageCaptionFromConf={siteConfig.site.primaryImage.imageCaption}
    imageWidthFromConf={siteConfig.site.primaryImage.imageWidth}
    imageHeightFromConf={siteConfig.site.primaryImage.imageHeight}
>
    <!-- Additional head content specific to this layout -->
    <Fragment slot="head">
        <link rel="preload" href="/assets/fonts/bricolage.woff2" as="font" type="font/woff2" crossorigin>
        <JsonLdHomePageBase
            faqList={[]}
            servicesList={[]}
            reviewsList={[]}
            disableReviews={false}
        />
    </Fragment>

    <!-- Body content -->

    <div class="bg-white" style="margin: 6px;">

        <video id="plane-bg" autoplay muted loop playsinline>
            <source src="assets/videos/plane-loop.webm" type="video/webm">
        </video>

        <script>
            const planeBgVideo = document.getElementById('plane-bg');
                planeBgVideo.playbackRate = 0.9;
                planeBgVideo.style.transition = 'opacity 1s';
                planeBgVideo.addEventListener('timeupdate', function() {
                planeBgVideo.style.opacity = (planeBgVideo.duration - planeBgVideo.currentTime < 2) ? 0 : 1;
            });
        </script>

        <!-- ═══════════ HERO ═══════════ -->
        <section class="relative h-[98vh] w-full overflow-hidden">

            <div id="plane-layer" class="absolute inset-0 z-20 pointer-events-none"></div>

            <img 
            src="assets/images/hero/imagem-ceu-principal-background-hero.jpg" 
            class="absolute inset-0 w-full h-full object-cover"
            alt="Sky background"
            >

            <div class="absolute inset-0 bg-black/10"></div>

            <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-6">

            <div class="absolute top-6 left-0 right-0 z-10 flex justify-center items-center gap-6">
                <a href="#" class="text-white/70 hover:text-white transition-colors">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
                </a>
                <a href="#" class="text-white/70 hover:text-white transition-colors">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <circle cx="12" cy="12" r="4"/>
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
                </a>
                <a href="#" class="text-white/70 hover:text-white transition-colors">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58a2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                    <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor"/>
                </svg>
                </a>
            </div>

            <img
                src="assets/images/hero/fred_com_uniforme_painted_trabalhando.png"
                alt="Fred, piloto campeão"
                class="w-48 h-48 md:w-56 md:h-56 lg:w-72 lg:h-72 rounded-full object-cover object-top border-3 border-white ring-[3px] ring-white/20 mb-8"
            />

                
            <h1 class="font-agrandir text-white text-5xl md:text-7xl lg:text-8xl leading-none font-extrabold">
                Voa <br> Fred!
            </h1>

            <p class="font-dark-shadow-white mt-6 max-w-xl text-white text-lg md:text-2xl leading-relaxed">
                "Eu ainda sou pequeno, mas o meu sonho de me tornar piloto é grande.
                Quem sonha alto, um dia decola."
            </p>

            </div>
        </section>


        <!-- ═══════════ ABOUT ═══════════ -->
        <section class="relative bg-white overflow-hidden px-6 xl:px-20 py-20 xl:py-28">

            <img
            src="./images/details/sky_clouds_trabalhando.svg"
            class="absolute bottom-0 left-0 w-full h-64 object-cover object-top opacity-20 pointer-events-none"
            alt=""
            >

            <div class="relative z-10 w-full flex flex-col">

            <!-- H2 — row própria, full width -->
            <div class="w-full flex items-start justify-between gap-4 mb-8 xl:mb-20">
                <h2 class="w-full min-w-0 font-agrandir text-black text-3xl xl:text-5xl leading-tight font-extrabold" style="word-spacing: -0.1em;">
                Oi, eu sou o Frederico!
                </h2>

                <!-- Foto pequena — só aparece no mobile, ao lado do título -->
                <img
                src="assets/images/articles/helicopero-fred-voo.jpeg"
                alt="Frederico"
                class="block xl:hidden w-24 h-28 object-cover object-top flex-shrink-0"
                style="box-shadow: 0 4px 16px rgba(0,0,0,0.15);"
                >
            </div>

            <!-- Grid 3 colunas — abaixo do h2 -->
            <div class="flex flex-col xl:grid xl:grid-cols-3 xl:gap-8 xl:items-stretch">

                <!-- COLUNA 1: textos -->
                <div class="flex flex-col">
                    <div class="font-dark-shadow space-y-4 text-black text-xl lg:text-2xl leading-relaxed">
                        <p>Mas muita gente me conhece como <strong class="not-italic text-black">Fly Fred</strong>.</p>
                        <p>Eu tenho 13 anos e o meu maior sonho é ser piloto de avião. Desde pequeno eu sou apaixonado por aviões, e hoje eu faço tudo o que posso pra chegar lá um dia.</p>
                        <p>Eu estudo bastante, leio livros sobre aviação e também treino em simulador, como se eu já estivesse pilotando de verdade. Eu gosto muito de aprender como tudo funciona dentro de um avião e como os pilotos se preparam.</p>
                    </div>
                </div>

                <!-- COLUNA 2: Foto grande — só desktop -->
                <div class="hidden xl:block xl:mt-12">
                <img
                    src="assets/images/articles/helicopero-fred-voo.jpeg"
                    alt="Frederico"
                    class="w-full h-full object-cover object-top"
                    style="box-shadow: 0 8px 32px rgba(0,0,0,0.15);"
                >
                </div>

                <!-- COLUNA 3: Botão alinhado ao fundo -->
                <div class="flex flex-col justify-center mt-10 xl:mt-6">
                <!-- <a href="#" class="inline-flex items-center gap-3 bg-[#f5d842] text-black font-bold text-lg px-8 py-4 rounded-full hover:bg-[#f0cc20] transition-colors self-start xl:self-auto">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    Acompanhe essa jornada
                </a> -->



                <div class="font-dark-shadow space-y-4 text-black text-xl lg:text-2xl leading-relaxed -mt-4 lg:mt-0">
                    <p>Uma coisa muito legal que já aconteceu comigo foi ter sido convidado pra conhecer o CT de treinamento da Azul! Também já tive a oportunidade de fazer voo de acrobacia, e foi uma das experiências mais incríveis da minha vida!</p>
                    <p>Eu também estudo inglês, porque sei que é muito importante pra quem quer ser piloto. E nas minhas redes sociais, onde já tenho mais de <strong>35.000 seguidores</strong>, eu compartilho a minha rotina, meus estudos e tudo que eu aprendo nesse caminho.</p>
                    <p>Eu ainda tenho muito pra aprender, mas eu nunca vou desistir do meu sonho. Um dia eu vou estar lá em cima, pilotando um avião de verdade.</p>
                </div>


                </div>

            </div><!-- fecha grid 3 colunas -->

            </div><!-- fecha flex col wrapper -->
        </section>  


        <!-- ═══════════ STORY CARDS ═══════════ -->

        <!-- ── CARD 1 ── -->
        <section class="relative w-full">
            <article class="story-card relative card-sky overflow-hidden mb-6 px-6 lg:px-20 py-0" data-chapter="1"
                >

            <!-- Wrapper flex col — mesmo padrão do about -->
            <div class="relative z-10 w-full flex flex-col">

                <!-- H2 com imagens de fundo apenas nessa row -->
                <div class="relative overflow-hidden flex flex-col justify-end px-6 lg:px-20 -mx-6 lg:-mx-20 mb-8 min-h-[220px] lg:min-h-[360px] lg:min-h-[560px]">
                    <!-- Camada 1: nuvem — só aqui -->
                    <div style="
                        position: absolute;
                        top: 0; left: 0;
                        width: 100%; height: 100%;
                        background: url('assets/images/articles/ceu-e-nuvens-reais.jpg') center/cover no-repeat;
                        mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0.9) 60%, rgba(0,0,0,0) 100%);
                        -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0.9) 60%, rgba(0,0,0,0) 100%);
                        z-index: 0;
                    "></div>

                    <!-- Camada 2: avião — só aqui -->
                    <div style="
                        position: absolute;
                        top: 0; left: 0;
                        width: 100%; height: 50%;
                        background: url('assets/images/articles/biplane_transparent.png') center/cover no-repeat;
                        opacity: 0.85;
                        mix-blend-mode: multiply;
                        mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0.8) 60%, rgba(0,0,0,0) 100%);
                        -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0.8) 60%, rgba(0,0,0,0) 100%);
                        z-index: 1;
                    "></div>

                    <!-- Avião decorativo -->
                    <!-- <img
                        src="assets/images/articles/biplane-deco.png"
                        alt=""
                        style="position: absolute; top: -1.5rem; right: -1rem; width: 10rem; pointer-events: none; z-index: 15; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.15));"
                    > -->

                    <!-- Ícone do capítulo + H2 — sobre as imagens -->
                    <div class="relative" style="z-index: 10;">
                        <svg class="mb-4 lg:mb-12" width="56" height="56" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <mask id="number-cut">
                            <rect width="40" height="40" fill="white"/>
                            <text x="20" y="27" text-anchor="middle" font-size="20" font-family="Agrandir, sans-serif" font-weight="bold" fill="black">1</text>
                            </mask>
                        </defs>
                        <circle cx="20" cy="20" r="20" fill="white" mask="url(#number-cut)"/>
                        </svg>

                        <h2 class="font-agrandir-white-shadow text-4xl lg:text-8xl leading-[0.95] font-extrabold pb-8"
                            style="text-shadow: 0 2px 12px rgba(80,140,200,0.18);">
                        Como tudo <br>começa
                        </h2>
                    </div>

                </div>

                <!-- Grid 3 colunas — parágrafo 1, vídeo, parágrafo 2 -->
                <div class="flex flex-col lg:grid lg:grid-cols-3 lg:gap-8 lg:items-stretch lg:mt-4">
                
                    <!-- COLUNA 1: parágrafo 1 -->
                    <div class="flex flex-col justify-end xl:justify-start">
                        <p class="font-dark-shadow text-xl lg:text-2xl leading-[1.4]">
                            Enquanto a maioria das crianças pedia fantasias de super-herói, 
                            eu só queria uma coisa: um uniforme de piloto.”
                        </p>
                    </div>

                    <!-- COLUNA 2: imagem -->
                    <div>

                        <div class="relative mt-8 lg:mt-24" style="min-height: 300px;">

                        <div class="flex flex-col justify-center mt-8 lg:mt-0">
                            <img
                            src="assets/images/articles/fred-com-uniforme.jpeg"
                            alt=""
                            class="w-full block"
                            style="height: auto; object-fit: contain;"
                            >
                        </div>              
                        
                        </div>

                    </div>

                    <!-- COLUNA 3: parágrafo 2 com bg fade -->
                    <div class="relative mt-8 lg:-mt-0 flex flex-col justify-end xl:justify-center -mx-7 lg:mx-0 pb-8 px-7">
                        <div class="hidden" style="
                        position: absolute;
                        top: 0; left: 0; right: 0; bottom: 0;
                        background: url('assets/images/articles/ceu-e-nuvens-reais.jpg') center center/cover no-repeat;
                        mask-image: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.7) 100%);
                        -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.7) 100%);
                        z-index: 0;
                        "></div>
                        <!-- <p class="font-agrandir-quote relative text-[1.3rem] leading-[1.2] pt-6 lg:hidden" style="z-index: 1;">
                        "Sou muito grato à equipe do CT pela oportunidade e pela experiência inesquecível, que fortaleceu ainda mais meu sonho de me tornar piloto."
                        </p> -->


                        <div class="lg:-mt-24" style="max-width: 460px;">
                            <p class="font-dark-shadow text-xl lg:text-2xl leading-[1.4]">
                                Com o tempo, percebi que não era apenas admiração de infância; 
                                era um interesse que voltava sempre, 
                                como se desde cedo alguma parte de mim já reconhecesse esse caminho.
                            </p>
                        </div>


                    </div>
                </div><!-- fecha grid 3 colunas -->

                <!-- Grid 2 colunas — texto e vídeo -->
                <div class="flex flex-col lg:grid lg:grid-cols-2 lg:gap-8 lg:items-stretch lg:mt-24">

                    <!-- COLUNA 1: texto -->
                    <div class="flex flex-col justify-center">
                        <p class="font-dark-shadow text-xl lg:text-2xl leading-[1.4]">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                        Nullam nibh enim, molestie tempor fringilla eget, dapibus id erat. 
                        Proin mattis faucibus mattis. 
                        </p>
                    </div>


                    <!-- COLUNA 1: imagem -->
                    <div class="flex flex-col justify-center mt-8 lg:mt-0">
                        <img
                        src="assets/images/articles/cockpit_junto_comandante.jpeg"
                        alt=""
                        class="w-full block"
                        style="height: auto; object-fit: contain;"
                        >
                    </div>

                </div><!-- fecha grid 2 colunas -->

            </div><!-- fecha flex col wrapper -->

            </article>
        </section>


        <!-- ── CARD 2 ── -->
        <section class="relative w-full">
            <article class="story-card relative card-sky-white-bg overflow-hidden mt-6 md:mt-24 mb-6 md:mb-12 px-6 md:px-20 py-0" data-chapter="2"
                >

            <!-- Wrapper flex col -->
            <div class="relative z-10 w-full flex flex-col">
                <!-- H2 com nuvem à direita -->
                <div class="relative flex flex-col justify-end px-6 md:px-20 -mx-6 md:-mx-20 mb-8 min-h-[300px] lg:min-h-[560px]">
                    <!-- Nuvem — lado direito, com fade nas bordas -->
                    <div style="
                        position: absolute;
                        top: 0; right: -2rem;
                        width: 55%; height: 100%;
                        background: url('assets/images/articles/ceu_nuvem_separada.png') center/contain no-repeat;
                        mask-image: linear-gradient(
                            to right,
                            rgba(0,0,0,1)    0%,
                            rgba(0,0,0,0.95) 20%,
                            rgba(0,0,0,0.85) 40%,
                            rgba(0,0,0,0.6)  55%,
                            rgba(0,0,0,0.3)  70%,
                            rgba(0,0,0,0.1)  85%,
                            rgba(0,0,0,0)    100%
                        ), linear-gradient(
                            to bottom,
                            rgba(0,0,0,0.9) 0%,
                            rgba(0,0,0,0.9) 60%,
                            rgba(0,0,0,0)   100%
                        );
                        -webkit-mask-image: linear-gradient(
                            to right,
                            rgba(0,0,0,1)    0%,
                            rgba(0,0,0,0.95) 20%,
                            rgba(0,0,0,0.85) 40%,
                            rgba(0,0,0,0.6)  55%,
                            rgba(0,0,0,0.3)  70%,
                            rgba(0,0,0,0.1)  85%,
                            rgba(0,0,0,0)    100%
                        );
                        mask-composite: intersect;
                        -webkit-mask-composite: destination-in;
                        z-index: 0;
                    "></div>

                    <!-- Ícone do capítulo + H2 — sobre as imagens -->
                    <div class="relative" style="z-index: 10;">
                        <svg class="mb-6 md:mb-12" width="56" height="56" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="20" cy="20" r="20" fill="black"/>
                        <text x="20" y="27" text-anchor="middle" font-size="20" fill="white" font-family="Agrandir, sans-serif" font-weight="bold">2</text>
                        </svg>

                        <h2 class="font-agrandir text-black text-4xl md:text-6xl lg:text-8xl leading-[0.95] font-extrabold pb-8">
                        Comece a<br>Sonhar Alto!
                        </h2>
                    </div>
                </div>

                <!-- Grid 3 colunas — texto, vídeo, texto -->
                <div class="flex flex-col md:grid md:grid-cols-3 md:gap-8 md:items-stretch -mt-24 md:mt-4">

                    <!-- COLUNA 1: texto -->
                    <div class="flex flex-col justify-start mt-24">
                        <p class="font-dark-shadow text-xl lg:text-2xl leading-[1.4]">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                        Nullam nibh enim, molestie tempor fringilla eget, dapibus id erat. 
                        Proin mattis faucibus mattis. 
                        </p>
                    </div>

                    <!-- COLUNA 2: texto -->
                    <div class="flex flex-col justify-center mt-8 md:mt-0">
                        <p class="font-dark-shadow text-xl lg:text-2xl leading-[1.4]">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                        Nullam nibh enim, molestie tempor fringilla eget, dapibus id erat. 
                        Proin mattis faucibus mattis. 
                        </p>
                    </div>

                    <!-- COLUNA 3: vídeo -->
                    <div class="relative mt-8 md:mt-0">
                        <video
                        src="assets/videos/primeiro_voo.mp4"
                        class="w-full block custom-video"
                        style="height: auto; object-fit: contain;"
                        playsinline
                        ></video>
                        <div class="custom-overlay absolute inset-0 flex items-center justify-center bg-black/30 cursor-pointer transition-opacity duration-200 z-20">
                        <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="36" cy="36" r="36" fill="rgba(0,0,0,0.55)"/>
                            <polygon points="28,22 54,36 28,50" fill="#fff"/>
                        </svg>
                        </div>
                    </div>

                    <!-- Nuvem — lado esquerdo, com fade nas bordas -->
                    <div 
                    style="position: absolute; 
                        bottom: -50px; 
                        md:left:-80px;
                        width: 40%; 
                        height: 50%;
                        background: url('assets/images/articles/ceu_nuvem_esquerda.png') center/contain no-repeat;
                        mask-image: linear-gradient(
                            to left,
                            rgba(0,0,0,1)    0%,
                            rgba(0,0,0,0.95) 20%,
                            rgba(0,0,0,0.85) 40%,
                            rgba(0,0,0,0.6)  55%,
                            rgba(0,0,0,0.3)  70%,
                            rgba(0,0,0,0.1)  85%,
                            rgba(0,0,0,0)    100%
                        ), linear-gradient(
                            to bottom,
                            rgba(0,0,0,0.9) 0%,
                            rgba(0,0,0,0.3) 60%,
                            rgba(0,0,0,0.1) 90%,
                            rgba(0,0,0,0)   100%
                        );
                        -webkit-mask-image: linear-gradient(
                            to left,
                            rgba(0,0,0,1)    0%,
                            rgba(0,0,0,0.95) 20%,
                            rgba(0,0,0,0.85) 40%,
                            rgba(0,0,0,0.6)  55%,
                            rgba(0,0,0,0.3)  70%,
                            rgba(0,0,0,0.1)  85%,
                            rgba(0,0,0,0)    100%
                        ), linear-gradient(
                            to bottom,
                            rgba(0,0,0,0.9) 0%,
                            rgba(0,0,0,0.3) 60%,
                            rgba(0,0,0,0.1) 90%,
                            rgba(0,0,0,0)   100%
                        );
                        mask-composite: intersect;
                        -webkit-mask-composite: destination-in;
                        z-index: 0;
                    "></div>

                </div><!-- fecha grid 3 colunas -->        


                
            </div><!-- fecha flex col wrapper -->

            </article>

            <!-- IMAGEM OVERLAY -->

            <img
                src="assets/images/articles/ceu_nuvem_esquerda.png"
                alt=""
                class="absolute left-15 -translate-x-1/2 bottom-[-130px] md:hidden md:bottom-[-160px] w-48 md:w-52 lg:w-64 z-30 pointer-events-none rotate-[-6deg]"
                style="
                    mask-image: linear-gradient(
                        to left,
                        rgba(0,0,0,1) 0%,
                        rgba(0,0,0,0.95) 20%,
                        rgba(0,0,0,0.9) 50%,
                        rgba(0,0,0,0.6) 60%,
                        rgba(0,0,0,0.3) 70%,
                        rgba(0,0,0,0.1) 85%,
                        rgba(0,0,0,0) 100%
                    ),
                    linear-gradient(
                        to bottom,
                        rgba(0,0,0,0.9) 0%,
                        rgba(0,0,0,0.3) 60%,
                        rgba(0,0,0,0.1) 90%,
                        rgba(0,0,0,0) 100%
                    );

                    -webkit-mask-image: linear-gradient(
                        to left,
                        rgba(0,0,0,1) 0%,
                        rgba(0,0,0,0.95) 20%,
                        rgba(0,0,0,0.9) 50%,
                        rgba(0,0,0,0.6) 60%,
                        rgba(0,0,0,0.3) 70%,
                        rgba(0,0,0,0.1) 85%,
                        rgba(0,0,0,0) 100%
                    ),
                    linear-gradient(
                        to bottom,
                        rgba(0,0,0,0.9) 0%,
                        rgba(0,0,0,0.3) 60%,
                        rgba(0,0,0,0.1) 90%,
                        rgba(0,0,0,0) 100%
                    );

                    mask-composite: intersect;
