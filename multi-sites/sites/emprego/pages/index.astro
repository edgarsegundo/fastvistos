---
import SharedHomeLayout from '../layouts/SharedHomeLayout.astro';
import { siteConfig } from '../site-config.ts';
import JsonLdHomePageBase from '../components/JsonLdHomePageBase.astro';
import HeroSection from '../components/HeroSection.astro';
import FooterSection from '../components/FooterSection.astro';
import HeaderSection from '../components/HeaderSection.astro';
import WowItWorks from '../components/WowItWorks.astro';
import CallToAction from '../components/CallToAction.astro';
import CarouselSection from '../components/CarouselSection.astro';
import Navigation from '../components/Navigation.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyUs from '../components/WhyUs.astro';

const { bodyClass = '', bodyStyle = '' } = Astro.props;
---

<SharedHomeLayout
    bodyClass={`${bodyClass} leading-normal tracking-normal`}
    bodyStyle={`${bodyStyle}`}
    themeToggleDisable={true}
    canonicalConf={siteConfig.site.canonical}
    faviconPathFromConf={siteConfig.site.faviconPath}
    seoFromConf={siteConfig.homePageConfig.seo}
    titleFromConf={siteConfig.homePageConfig.seo.title}
    descriptionFromConf={siteConfig.homePageConfig.seo.description}
    authorNameFromConf={siteConfig.site.authorName}
    imageFromConf={null}
    imageUrlFromConf={siteConfig.site.primaryImage.url}
    imageCaptionFromConf={siteConfig.site.primaryImage.alt}
    imageWidthFromConf={siteConfig.site.primaryImage.width}
    imageHeightFromConf={siteConfig.site.primaryImage.height}
>
    <!-- Additional head content specific to this layout -->
    <Fragment slot="head">
        <link
          href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Inter:wght@400;500;600&family=Roboto:wght@400;500&family=Bricolage+Grotesque:wght@400;500;600;700&display=swap"
          rel="stylesheet"
        />
        <JsonLdHomePageBase
            faqList={[]}
            servicesList={[]}
            reviewsList={[]}
            disableReviews={false}
        />
    </Fragment>

    <div>
        <Navigation />
        <HeroSection />
        <HowItWorks />

        <h2 class="font-title font-bold mt-16 text-center text-neutral-dark"
          style="font-size: 28px;">
        Porque o emprego aqui é diferente?
        </h2>

        <WhyUs />

        <div class="container mx-auto max-w-3xl px-8 flex flex-col items-center">
          <h2 class="font-title font-bold mt-16 text-center text-neutral-dark"
            style="font-size: 28px;">
          EMPRESAS
          </h2>

          <section class="py-2 bg-gray-100 px-4 flex justify-center">
            <div class="max-w-xl w-full rounded-3xl shadow-lg border border-gray-200 p-8 sm:p-10 bg-bg-card">

              <!-- Logos inline -->
              <div class="flex items-center gap-4 mb-6">
                <img src="assets/images/hero/empregoaqui_two_arrows.avif" alt="Emprego Aqui" class="h-12 object-contain">
                <img src="assets/images/services/handshake.avif" alt="Emprego Aqui" class="h-16 object-contain">
              </div>

              <!-- Texto -->
              <p class="deck leading-relaxed text-neutral-dark" style="font-size: 20px;">
                Clique no botão abaixo e acesse centenas de currículos de candidatos qualificados. Com o Emprego Aqui, sua empresa contrata de forma rápida, segura e eficiente.
              </p>

            </div>
          </section>

          <div class="w-full flex flex-col items-center px-4">
            <a
              href="https://admin.empregoaqui.com.br/api/posts/search-page/"
              class="btn-cta"
            >
              Procurar candidatos
            </a>
          </div>
        </div>

    </div>

    <main class="min-h-screen">
        <!-- <CarouselSection /> -->
        <!-- <FooterSection /> -->
    </main>
</SharedHomeLayout>

<style is:global>
</style>
