---
// Emprego Aqui — Landing Page M3 (design ASA Propaganda)
// Reconstruída em Astro + Tailwind v4. Fonte de verdade: docs/asapropaganda/etapa1+2.
import SharedHomeLayout from '../layouts/SharedHomeLayout.astro';
import { siteConfig } from '../site-config.ts';
import JsonLdHomePageBase from '../components/JsonLdHomePageBase.astro';

import EmpregoNavbar from '../components/EmpregoNavbar.astro';
import EmpregoHero from '../components/EmpregoHero.astro';
import EmpregoStrip from '../components/EmpregoStrip.astro';
import EmpregoComoFunciona from '../components/EmpregoComoFunciona.astro';
import EmpregoVideo from '../components/EmpregoVideo.astro';
import EmpregoPorque from '../components/EmpregoPorque.astro';
import EmpregoNumeros from '../components/EmpregoNumeros.astro';
import EmpregoDepoimentos from '../components/EmpregoDepoimentos.astro';
import EmpregoEmpresasMarquee from '../components/EmpregoEmpresasMarquee.astro';
import EmpregoParaEmpresas from '../components/EmpregoParaEmpresas.astro';
import EmpregoFaq from '../components/EmpregoFaq.astro';
import EmpregoCtaFinal from '../components/EmpregoCtaFinal.astro';
import EmpregoFooter from '../components/EmpregoFooter.astro';
import EmpregoWppBar from '../components/EmpregoWppBar.astro';

const { bodyClass = '', bodyStyle = '' } = Astro.props;
---

<SharedHomeLayout
    bodyClass={`${bodyClass} antialiased`}
    bodyStyle={`${bodyStyle}`}
    themeToggleDisable={true}
    canonicalConf={siteConfig.site.canonical}
    faviconPathFromConf={siteConfig.site.faviconPath}
    seoFromConf={siteConfig.homePageConfig.seo}
    titleFromConf={siteConfig.homePageConfig.seo.title}
    descriptionFromConf={siteConfig.homePageConfig.seo.description}
    authorNameFromConf={siteConfig.site.authorName}
    imageFromConf={null}
    imageUrlFromConf={siteConfig.site.primaryImage.url}
    imageCaptionFromConf={siteConfig.site.primaryImage.alt}
    imageWidthFromConf={siteConfig.site.primaryImage.width}
    imageHeightFromConf={siteConfig.site.primaryImage.height}
>
    <Fragment slot="head">
        <!-- Preload do LCP: fundo do Hero (slide 1). É background-image em CSS,
             então sem isto o navegador só o descobre após baixar/parsear o CSS.
             Antecipa o download → melhora LCP e "Descoberta de solicitações de LCP". -->
        <link
          rel="preload"
          as="image"
          href="/assets/images/v2/emprego-aqui-hero-bg-candidatos-slide-1.webp"
          fetchpriority="high"
        />
        <!-- Fontes sem bloquear renderização: carrega como preload e vira
             stylesheet no onload. Com display=swap, o texto aparece de imediato
             na fonte fallback. Resolve "Solicitações que bloquearam a renderização". -->
        <link
          rel="preload"
          as="style"
          href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
          onload="this.onload=null;this.rel='stylesheet'"
        />
        <noscript>
          <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
            rel="stylesheet"
          />
        </noscript>
        <JsonLdHomePageBase
            faqList={[]}
            servicesList={[]}
            reviewsList={[]}
            disableReviews={false}
        />
    </Fragment>

    <EmpregoNavbar />
    <EmpregoHero />
    <EmpregoStrip />
    <EmpregoComoFunciona />
    <EmpregoVideo />
    <EmpregoPorque />
    <EmpregoNumeros />
    <EmpregoDepoimentos />
    <!-- <EmpregoEmpresasMarquee /> -->
    <EmpregoParaEmpresas />
    <EmpregoFaq />
    <EmpregoCtaFinal />
    <EmpregoFooter />
    <EmpregoWppBar />
</SharedHomeLayout>

<script>
  // Scroll-reveal: revela elementos .reveal quando entram no viewport.
  (function () {
    const els = document.querySelectorAll('.reveal');
    if (!els.length) return;
    if (!('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('visible')); // fallback: mostra tudo
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    els.forEach((el) => io.observe(el));
  })();
</script>
