---
// Navigation component with logo and menu
---

<nav id="header" class="w-full z-50 top-0 text-white">
  <div class="w-full container mx-auto flex flex-wrap items-center justify-between py-4 border-b border-gray-200 mb-2 px-2">
    <div class="pl-4 flex flex-col items-start font-bold">
      <img alt="logo" data-ssr-src-done="true" fetchpriority="high" 
            src="assets/images/hero/empregoaqui_two_arrows.avif" 
            class="h-[60px] object-contain object-left">
      <span class="text-xs text-gray-500 mt-0.5">Aqui você encontra o emprego que tanto procura.</span>
    </div>

    <div class="block lg:hidden pr-4">
      <button 
        id="nav-toggle"
        aria-label="Abrir menu"
        class="flex items-center p-1 text-pink-800 hover:text-gray-900 focus:outline-none transform transition hover:scale-105 duration-300 ease-in-out"
      >
        <svg 
          class="h-8 w-8"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#091F45"
          xmlns="http://www.w3.org/2000/svg"
        >
          <title>Menu</title>
          <line x1="3" y1="6" x2="21" y2="6" stroke-width="1" stroke-linecap="round"/>
          <line x1="3" y1="12" x2="21" y2="12" stroke-width="1" stroke-linecap="round"/>
          <line x1="3" y1="18" x2="21" y2="18" stroke-width="1" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>
  <hr class="border-b border-gray-100 opacity-25 my-0 py-0" />
</nav>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const navToggle = document.getElementById('nav-toggle');
    const navContent = document.getElementById('nav-content');
    if (navToggle && navContent) {
      navToggle.addEventListener('click', function () {
        navContent.classList.toggle('hidden');
      });
    }
  });
</script>
