---
/**
 * Empresas — trust block + marquee animado de logos.
 * Marquee: 22s linear infinite, pausa no hover, fade nas laterais.
 *
 * ⚠️ LOGOS PARCEIROS FALTANDO — usando placeholders de texto por setor (decisão acordada).
 * Substituir .logo-placeholder pelos logos reais (SVG/WebP) quando disponíveis.
 * ⚠️ Copy do trust block é provisória — revisar.
 */
const searchUrl = 'https://admin.empregoaqui.com.br/api/posts/search-page/';

// Placeholders por setor (não são marcas reais) — trocar pelos logos das empresas parceiras
const setores = ['Comércio', 'Indústria', 'Serviços', 'Logística', 'Varejo', 'Alimentação', 'Construção', 'Saúde'];
---

<section class="empresas" aria-labelledby="empresas-title">
  <div class="wrap empresas__trust reveal">
    <div class="empresas__trust-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01"/></svg>
    </div>
    <div class="empresas__trust-text">
      <h2 class="empresas__trust-title" id="empresas-title">Negócios da região já contratam por aqui</h2>
      <p class="empresas__trust-sub">De pequenos comércios a indústrias — empresas de Campinas e região encontram candidatos todos os dias.</p>
    </div>
    <a href={searchUrl} class="btn btn--ghost-coral empresas__trust-cta" target="_blank" rel="noopener">Quero contratar</a>
  </div>

  <div class="marquee-wrap" aria-hidden="true">
    <div class="marquee-track">
      <div class="marquee-inner">
        {setores.map((s) => <span class="logo-placeholder">{s}</span>)}
      </div>
      <div class="marquee-inner">
        {setores.map((s) => <span class="logo-placeholder">{s}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .empresas { background: var(--color-surface); padding: 48px 0 0; }

  .empresas__trust {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .empresas__trust-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(242, 139, 48, .1);
    color: var(--color-cta);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .empresas__trust-text { flex: 1; }
  .empresas__trust-title { font-family: var(--font-display); font-size: clamp(20px, 2.4vw, 26px); font-weight: 800; color: var(--color-text-main); line-height: 1.2; }
  .empresas__trust-sub { font-size: 15px; color: var(--color-muted); line-height: 1.6; margin-top: 6px; }
  .empresas__trust-cta { flex-shrink: 0; }

  /* Marquee */
  .marquee-wrap { width: 100%; overflow: hidden; position: relative; margin-top: 36px; padding-bottom: 48px; }
  .marquee-wrap::before,
  .marquee-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .marquee-wrap::before { left: 0; background: linear-gradient(90deg, var(--color-surface), transparent); }
  .marquee-wrap::after { right: 0; background: linear-gradient(-90deg, var(--color-surface), transparent); }
  .marquee-track { display: flex; width: max-content; }
  .marquee-inner { display: flex; align-items: center; gap: 20px; padding: 0 10px; animation: marquee 22s linear infinite; }
  .marquee-wrap:hover .marquee-inner { animation-play-state: paused; }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-100%); }
  }

  .logo-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 130px;
    height: 56px;
    padding: 0 24px;
    border: 1px solid rgba(30, 34, 55, .1);
    border-radius: 10px;
    background: #fff;
    color: var(--color-muted);
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: .02em;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .empresas__trust { flex-direction: column; text-align: center; }
    .empresas__trust-sub { margin-inline: auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-inner { animation: none; }
  }
</style>
