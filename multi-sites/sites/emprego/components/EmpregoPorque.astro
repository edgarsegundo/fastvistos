---
/**
 * Por Que Aqui — grid 2×2 de cards de benefício sobre fundo claro.
 * Borda coral animada à esquerda no hover. Um card é destaque (com tag).
 * Mobile ≤640px: 1 coluna.
 *
 * ⚠️ Os 2 primeiros cards vêm do etapa2; os 2 últimos são copy provisória — revisar.
 */
const cards = [
  {
    icon: 'pin',
    title: 'Vagas perto de você',
    desc: 'Focado 100% na Região Metropolitana de Campinas — oportunidades pertinho de casa.',
  },
  {
    icon: 'chat',
    title: 'Só precisa do WhatsApp',
    desc: 'Nada de apps novos ou senhas. Tudo acontece no WhatsApp que você já usa todo dia.',
    destaque: true,
    tag: 'O canal que você já conhece',
  },
  {
    icon: 'free',
    title: '100% gratuito para você',
    desc: 'Criar seu currículo e ser encontrado por empresas não custa nada.',
  },
  {
    icon: 'bolt',
    title: 'Currículo pronto na hora',
    desc: 'Nossa IA monta um currículo profissional em 2 minutos, do jeito que as empresas querem ver.',
  },
];

const icons: Record<string, string> = {
  pin: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  chat: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  free: '<path d="M20 12v9H4v-9"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>',
  bolt: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
};
---

<section class="porque" aria-labelledby="porque-title">
  <div class="wrap">

    <div class="porque__header reveal">
      <p class="section-label">Por que o Emprego Aqui</p>



      <h2 class="section-title" id="porque-title">O jeito mais fácil de<br>conseguir emprego em Campinas</h2>
      <p class="section-sub">Sem burocracia, sem custo e do jeito que o brasileiro já se comunica.</p>
    </div>

    <div class="porque__grid">
      {cards.map((card) => (
        <div class={`card-beneficio reveal${card.destaque ? ' card-beneficio--destaque' : ''}`}>
          <div class="card-beneficio__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" set:html={icons[card.icon]} />
          </div>
          <h3 class="card-beneficio__title">{card.title}</h3>
          <p class="card-beneficio__desc">{card.desc}</p>
          {card.tag && <div class="card-beneficio__tag">{card.tag}</div>}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .porque { padding: 96px 0; background: var(--color-surface); }
  .porque__header { text-align: center; margin-bottom: 56px; }
  .porque__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }

  .card-beneficio {
    background: #fff;
    border-radius: var(--radius);
    padding: 32px 28px;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(30, 34, 55, .06);
    transition: all .25s;
    position: relative;
    overflow: hidden;
  }
  .card-beneficio:hover { transform: translateY(-4px); box-shadow: var(--shadow); }

  /* Borda coral animada à esquerda */
  .card-beneficio::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--color-cta);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform .3s;
  }
  .card-beneficio:hover::before { transform: scaleY(1); }

  .card-beneficio__icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(242, 139, 48, .1);
    color: var(--color-cta);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .card-beneficio__title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 800;
    color: var(--color-text-main);
    margin-bottom: 8px;
  }
  .card-beneficio__desc { font-size: 15px; color: var(--color-muted); line-height: 1.65; }

  .card-beneficio__tag {
    display: inline-block;
    margin-top: 16px;
    padding: 4px 12px;
    border-radius: 20px;
    background: rgba(242, 139, 48, .12);
    color: var(--color-cta);
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .porque__grid { grid-template-columns: 1fr; }
  }
</style>
