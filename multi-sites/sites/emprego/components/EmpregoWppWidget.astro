---
/**
 * Widget WhatsApp — simulação de chat exibida na coluna direita do hero (desktop).
 * Oculto em mobile (controlado pelo .hero__right do EmpregoHero).
 * Animação de entrada + bolhas + digitação 100% via CSS (sem JS).
 */
---

<div class="wpp-widget">
  <div class="wpp-widget__phone">

    <!-- Header: avatar + nome + status -->
    <div class="wpp-widget__header">
      <div class="wpp-widget__avatar">
        <img
          src="/assets/images/v2/emprego-aqui-avatar-whatsapp-widget.webp"
          alt="Emprego Aqui"
          width="36"
          height="36"
        />
      </div>
      <div class="wpp-widget__info">
        <div class="wpp-widget__name">Emprego Aqui</div>
        <div class="wpp-widget__status">online agora</div>
      </div>
    </div>

    <!-- Chat -->
    <div class="wpp-widget__chat">
      <div class="wpp-widget__bubble wpp-widget__bubble--in">
        Oi! Vi que você está buscando emprego em Campinas 👋
      </div>
      <div class="wpp-widget__bubble wpp-widget__bubble--in delay-1">
        Nossa IA encontrou <strong>3 vagas</strong> perto de você
      </div>
      <div class="wpp-widget__bubble wpp-widget__bubble--out delay-2">
        Sério?! Que vagas são essas? 😮
      </div>
      <div class="wpp-widget__bubble wpp-widget__bubble--in delay-3">
        Vagas com salário compatível, pertinho de você 📍 Quer ver?
      </div>
    </div>

    <!-- Input simulado -->
    <div class="wpp-widget__footer">
      <div class="wpp-widget__input">Criar meu currículo grátis...</div>
      <div class="wpp-widget__send" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="#fff"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
      </div>
    </div>

  </div>
</div>

<style>
  .wpp-widget {
    width: 300px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, .45);
    animation: wppEntrance .7s cubic-bezier(.34, 1.56, .64, 1) .5s both;
  }
  @keyframes wppEntrance {
    from { opacity: 0; transform: translateY(32px) scale(.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .wpp-widget__phone { background: var(--color-wpp-bg); display: flex; flex-direction: column; }

  .wpp-widget__header {
    background: var(--color-wpp-header);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .wpp-widget__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }
  .wpp-widget__avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .wpp-widget__name { font-family: var(--font-display); font-size: 13px; font-weight: 700; color: #E9EDEF; }
  .wpp-widget__status { font-size: 11px; color: #8696A0; margin-top: 1px; }

  .wpp-widget__chat {
    padding: 16px 12px 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 180px;
    background: var(--color-wpp-bg);
  }

  .wpp-widget__bubble {
    max-width: 85%;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 12.5px;
    line-height: 1.5;
    color: #E9EDEF;
    opacity: 0;
    animation: bubbleIn .4s ease forwards;
  }
  .wpp-widget__bubble--in  { background: var(--color-wpp-bubble-in); align-self: flex-start; }
  .wpp-widget__bubble--out { background: var(--color-wpp-bubble-out); align-self: flex-end; }

  .wpp-widget__bubble.delay-1 { animation-delay: 1.2s; }
  .wpp-widget__bubble.delay-2 { animation-delay: 2.4s; }
  .wpp-widget__bubble.delay-3 { animation-delay: 3.6s; }

  @keyframes bubbleIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .wpp-widget__footer {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: var(--color-wpp-bg);
    border-top: 1px solid rgba(255, 255, 255, .06);
  }
  .wpp-widget__input {
    flex: 1;
    background: #2A3942;
    border-radius: 20px;
    padding: 8px 14px;
    font-size: 12px;
    color: #8696A0;
  }
  .wpp-widget__send {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-wpp);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
</style>
