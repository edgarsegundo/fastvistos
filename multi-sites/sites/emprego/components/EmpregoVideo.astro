---
/**
 * Seção de Vídeo — texto à esquerda + player à direita.
 * Embed do YouTube com lazy-loading (facade): carrega só a thumbnail do CDN
 * do YouTube até o clique, então injeta o iframe. Otimizado p/ Lighthouse.
 * Ref.: docs/*Manual-Vídeo-YouTube-Site.md
 * Seção abaixo da dobra → usa loading="lazy" e SEM fetchpriority="high".
 */
import { siteConfig } from '../site-config.ts';
const { telephone, message, url } = siteConfig.site.whatsapp;
const whatsappUrl =
  `${url}${telephone.replace(/\D/g, '')}?text=${encodeURIComponent(message)}`;

const videoId = 'wfUA5ZJstgM';
// maxresdefault: 1280x720 (16:9, nítida) — o vídeo foi enviado em HD.
const thumbUrl = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
---

<link rel="preconnect" href="https://www.youtube-nocookie.com">
<link rel="preconnect" href="https://i.ytimg.com">

<section class="video-sec" aria-labelledby="video-title">
  <div class="wrap video-sec__inner reveal">

    <div class="video-sec__content">
      <p class="section-label">Veja como é simples</p>
      <h2 class="section-title section-title--white" id="video-title">Do WhatsApp<br>ao emprego</h2>
      <p class="section-sub section-sub--white">
        Assista e veja como funciona na prática. Em menos de 2 minutos você entende
        por que o Emprego Aqui é diferente de tudo que você já usou.
      </p>
      <a href={whatsappUrl} class="btn btn--coral video-sec__cta" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Quero começar agora
      </a>
    </div>

    <div class="video-sec__player">
      <button
        class="video-thumb"
        id="videoThumb"
        type="button"
        data-video-id={videoId}
        aria-label="Reproduzir vídeo: Do WhatsApp ao emprego"
      >
        <img
          src={thumbUrl}
          alt="Vídeo demonstrativo do Emprego Aqui"
          width="1280"
          height="720"
          decoding="async"
          loading="lazy"
        />
        <span class="play-button" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </span>
      </button>
    </div>

  </div>
</section>

<style>
  .video-sec { padding: 96px 0; background: var(--color-bg-dark); }
  .video-sec__inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 56px;
    align-items: center;
  }

  .video-sec__cta { margin-top: 28px; }

  /* Player (facade do YouTube) */
  .video-sec__player { width: 100%; }
  .video-thumb {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    cursor: pointer;
    aspect-ratio: 16 / 9;       /* zero CLS */
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: #000;
  }
  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Botão de play */
  .video-thumb .play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(20, 23, 42, .6);
    color: #fff;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s, transform .2s;
  }
  .video-thumb .play-button svg { margin-left: 4px; }
  .video-thumb:hover .play-button {
    background: rgba(20, 23, 42, .85);
    transform: translate(-50%, -50%) scale(1.06);
  }

  /* Iframe injetado após o clique */
  .video-thumb iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── MOBILE ── */
  @media (max-width: 860px) {
    .video-sec { padding: 72px 0; }
    .video-sec__inner { grid-template-columns: 1fr; gap: 36px; }
  }
</style>

<script>
  (function () {
    const thumb = document.getElementById('videoThumb');
    if (!thumb) return;
    thumb.addEventListener('click', () => {
      const id = thumb.getAttribute('data-video-id');
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
      iframe.title = 'Vídeo empregoaqui.com.br';
      iframe.allow = 'autoplay; encrypted-media';
      iframe.setAttribute('allowfullscreen', '');
      // Estilos inline: o iframe é criado em runtime e não recebe o
      // atributo de escopo do Astro, então o CSS .video-thumb iframe não
      // se aplicaria a ele.
      iframe.style.cssText =
        'position:absolute;top:0;left:0;width:100%;height:100%;border:0;';
      thumb.innerHTML = '';
      thumb.appendChild(iframe);
    });
  })();
</script>
