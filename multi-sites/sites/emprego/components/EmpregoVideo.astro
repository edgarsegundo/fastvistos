---
/**
 * Seção de Vídeo — texto à esquerda + player à direita.
 * Vídeo autoplay/loop/muted; botão de toggle de som.
 */
import { siteConfig } from '../site-config.ts';
const whatsappUrl = siteConfig.site.whatsapp.url;
---

<section class="video-sec" aria-labelledby="video-title">
  <div class="wrap video-sec__inner reveal">

    <div class="video-sec__content">
      <p class="section-label">Veja como é simples</p>
      <h2 class="section-title" id="video-title">Do WhatsApp<br>ao emprego</h2>
      <p class="section-sub">
        Assista e veja como funciona na prática. Em menos de 2 minutos você entende
        por que o Emprego Aqui é diferente de tudo que você já usou.
      </p>
      <a href={whatsappUrl} class="btn btn--coral video-sec__cta" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Quero começar agora
      </a>
    </div>

    <div class="video-sec__player">
      <div class="video-real-wrap">
        <video
          id="heroVideo"
          class="video-real"
          src="/assets/images/hero/hero-desktop.webm"
          autoplay
          loop
          muted
          playsinline
          aria-label="Vídeo demonstrativo do Emprego Aqui"
        ></video>
        <button class="video-sound-btn" id="videoSoundBtn" type="button" aria-label="Ligar som do vídeo">
          <svg class="icon-muted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
          <svg class="icon-unmuted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
        </button>
      </div>
    </div>

  </div>
</section>

<style>
  .video-sec { padding: 96px 0; background: #fff; }
  .video-sec__inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 56px;
    align-items: center;
  }

  .video-sec__cta { margin-top: 28px; }

  /* Player */
  .video-sec__player { width: 100%; }
  .video-real-wrap {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: var(--color-bg-dark);
  }
  .video-real {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Botão de som */
  .video-sound-btn {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: rgba(20, 23, 42, .6);
    color: #fff;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s;
  }
  .video-sound-btn:hover { background: rgba(20, 23, 42, .85); }
  .video-sound-btn .icon-unmuted { display: none; }
  .video-sound-btn.is-on .icon-muted { display: none; }
  .video-sound-btn.is-on .icon-unmuted { display: block; }

  /* ── MOBILE ── */
  @media (max-width: 860px) {
    .video-sec { padding: 72px 0; }
    .video-sec__inner { grid-template-columns: 1fr; gap: 36px; }
  }
</style>

<script>
  (function () {
    const video = document.getElementById('heroVideo') as HTMLVideoElement | null;
    const btn = document.getElementById('videoSoundBtn');
    if (!video || !btn) return;
    btn.addEventListener('click', () => {
      video.muted = !video.muted;
      const on = !video.muted;
      btn.classList.toggle('is-on', on);
      btn.setAttribute('aria-label', on ? 'Desligar som do vídeo' : 'Ligar som do vídeo');
      if (on) video.play().catch(() => {});
    });
  })();
</script>
